---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getLangFromUrl, getTranslation, getLocalizedPath } from '@/i18n';
import CustomCursor from '@/components/CustomCursor.astro';
import ScrollNav from '@/components/ScrollNav.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalPath?: string;
  enCanonicalPath?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const { title, description, ogImage, ogType = 'website', canonicalPath, enCanonicalPath, jsonLd, noindex = true } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = getTranslation(lang);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://sidneycarron.com';

const currentPath = Astro.url.pathname;
const frPath = canonicalPath || currentPath.replace(/^\/en/, '') || '/';
const enPath = enCanonicalPath
  ? getLocalizedPath('en', enCanonicalPath)
  : canonicalPath
    ? getLocalizedPath('en', canonicalPath)
    : (currentPath.startsWith('/en') ? currentPath : getLocalizedPath('en', currentPath));

const canonicalUrl = `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/og-default.jpg`;
---

<!DOCTYPE html>
<html lang={lang === 'fr' ? 'fr' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sidney Carron" />
    <meta name="theme-color" content="#ffffff" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={`${siteUrl}${frPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${frPath}`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'fr' ? 'en_US' : 'fr_FR'} />
    <meta property="og:site_name" content="Sidney Carron" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@400;500;700&display=swap" rel="stylesheet" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-dvh max-w-[2400px] mx-auto">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-text focus:text-white focus:px-4 focus:py-2 focus:text-caption focus:font-sans"
    >
      {t('a11y.skip')}
    </a>
    <CustomCursor />
    <ScrollNav />
    <slot />
  </body>
</html>
