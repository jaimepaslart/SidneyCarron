---
import PageLayout from '@/layouts/PageLayout.astro';
import { getLangFromUrl, getTranslation, getLocalizedPath } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = getTranslation(lang);
---

<PageLayout
  title={`${t('404.title')} — Sidney Carron`}
  description={t('404.message')}
  noindex={true}
>
  <div class="flex-1 flex items-center justify-center min-h-[60vh]">
    <div class="text-center px-gutter-sm">
      <p class="font-serif text-8xl font-light text-text">404</p>
      <h1 class="font-serif font-light text-2xl text-text mt-4">{t('404.title')}</h1>
      <p class="font-sans text-base text-secondary mt-4 max-w-md mx-auto">
        {t('404.message')}
      </p>
      <a
        href={getLocalizedPath(lang, '/')}
        class="inline-block mt-8 font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease"
      >
        &larr; {t('404.back_home')}
      </a>
    </div>
  </div>
</PageLayout>
