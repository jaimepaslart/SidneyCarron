---
import GalleryPage from '@/components/pages/GalleryPage.astro';
import { locations } from '@/data/locations';
import { getGallery } from '@/data/gallery-loader';

export function getStaticPaths() {
  return locations.map(loc => ({
    params: { location: loc.slug },
    props: { location: loc },
  }));
}

const { location } = Astro.props;
const gallery = getGallery(location.slug);
---
{gallery && <GalleryPage location={location} gallery={gallery} lang="fr" />}
