---
interface Props {
  text: string;
  tag?: string;
  class?: string;
  /** If true, waits for 'hero:phase-name' event instead of IntersectionObserver */
  heroSequence?: boolean;
  /** Base delay in ms added before char stagger (for multi-line sequencing) */
  heroDelay?: number;
}

const {
  text,
  tag: Tag = 'h1',
  class: className = '',
  heroSequence = false,
  heroDelay = 0,
} = Astro.props;
---

<Tag
  class={`text-reveal ${className}`}
  data-splitting
  data-hero-sequence={heroSequence ? 'true' : undefined}
  data-hero-delay={heroDelay > 0 ? String(heroDelay) : undefined}
>
  {text}
</Tag>

<script>
  import Splitting from 'splitting';

  function initTextReveal() {
    // Clean up stale animations from HMR reloads
    document.querySelectorAll('.text-reveal[data-split-done]').forEach((el) => {
      el.querySelectorAll('.char').forEach((c) => c.getAnimations().forEach((a) => a.cancel()));
      el.removeAttribute('data-split-done');
    });

    const elements = document.querySelectorAll('.text-reveal:not([data-split-done])');
    if (!elements.length) return;

    Splitting({ target: '.text-reveal:not([data-split-done])', by: 'chars' });
    elements.forEach((el) => el.setAttribute('data-split-done', ''));

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    elements.forEach((el) => {
      const chars = el.querySelectorAll('.char') as NodeListOf<HTMLElement>;
      const isHeroSequence = el.hasAttribute('data-hero-sequence');

      // Set initial state: hidden
      chars.forEach((char) => {
        char.style.display = 'inline-block';
        if (prefersReduced) {
          char.style.opacity = '1';
          char.style.transform = 'none';
        } else {
          char.style.opacity = '0';
          char.style.transform = 'translateY(60%) rotateX(-40deg)';
          char.style.transformOrigin = 'center bottom';
          char.style.willChange = 'opacity, transform';
        }
      });

      if (prefersReduced) return;

      const baseDelay = parseInt((el as HTMLElement).dataset.heroDelay || '0', 10);

      function revealChars() {
        // Clear all transitions at once, then flush with a single reflow
        chars.forEach((char) => { char.style.transition = 'none'; });
        if (chars.length) void (chars[0] as HTMLElement).offsetHeight;
        chars.forEach((char, i) => {
          setTimeout(() => {
            char.style.transition = 'opacity 1.2s cubic-bezier(0.165, 0.84, 0.44, 1), transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1)';
            char.style.opacity = '1';
            char.style.transform = 'translateY(0) rotateX(0deg)';
          }, baseDelay + i * 25);
        });
      }

      if (isHeroSequence) {
        // Wait for the hero orchestrator to trigger
        document.addEventListener('hero:phase-name', () => revealChars(), { once: true });
      } else {
        // Standard IntersectionObserver for non-hero TextReveals
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                revealChars();
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px', threshold: 0.1 }
        );
        observer.observe(el);
      }
    });
  }

  document.addEventListener('astro:page-load', initTextReveal);
</script>
