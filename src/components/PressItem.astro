---
import { getTranslation, type Lang } from '@/i18n';

interface Props {
  article: {
    title: string;
    publication: string;
    date: string;
    excerpt?: string;
    url?: string;
    pdf?: string;
    image?: string;
  };
  lang: Lang;
}

const { article, lang } = Astro.props;
const t = getTranslation(lang);

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const day = String(d.getDate()).padStart(2, '0');
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const year = d.getFullYear();
  return `${day}.${month}.${year}`;
}
---

<article class="flex flex-col md:flex-row gap-6 py-8">
  {article.image && (
    <div class="w-full md:w-[100px] shrink-0">
      <img
        src={article.image}
        alt={article.title}
        width="100"
        height="100"
        loading="lazy"
        class="w-full md:w-[100px] md:h-[100px] object-cover rounded"
      />
    </div>
  )}
  <div class="flex-1">
    <p class="text-xs text-secondary uppercase tracking-widest">
      {article.publication} — {formatDate(article.date)}
    </p>
    <h2 class="font-sans italic text-xl text-text mt-2">
      {article.url ? (
        <a
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-hover transition-colors duration-hover ease"
        >
          {article.title}
        </a>
      ) : (
        article.title
      )}
    </h2>
    {article.excerpt && (
      <p class="text-base text-secondary mt-2 line-clamp-2">{article.excerpt}</p>
    )}
    <div class="flex gap-4 mt-3">
      {article.url && (
        <a
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-widest text-text hover:text-hover underline underline-offset-2 transition-colors duration-hover ease"
        >
          {t('press.read_article')}
        </a>
      )}
      {article.pdf && (
        <a
          href={article.pdf}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-widest text-text hover:text-hover underline underline-offset-2 transition-colors duration-hover ease"
        >
          {t('press.download_pdf')}
        </a>
      )}
    </div>
  </div>
</article>
