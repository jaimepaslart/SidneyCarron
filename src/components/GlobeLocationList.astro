---
import { locations } from '@/data/locations';
import { getGallery } from '@/data/gallery-loader';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const sortedLocations = [...locations].sort((a, b) => b.photoCount - a.photoCount);
---

<div class="hidden md:block">
  <ul class="globe-list">
    {sortedLocations.map((loc) => {
      const name = lang === 'en' ? loc.name_en : loc.name_fr;
      const country = lang === 'en' ? loc.country_en : loc.country_fr;
      const gallery = getGallery(loc.slug);
      const thumbnail = loc.cover || gallery?.images?.[0]?.src || '';
      return (
        <li class="globe-list__row">
          <a
            href={getLocalizedPath(lang, `/works/${loc.slug}/`)}
            data-globe-loc={loc.slug}
            data-lat={loc.coords.lat}
            data-lng={loc.coords.lng}
            class="globe-list__item group"
          >
            {thumbnail && (
              <div class="globe-list__polaroid">
                <div class="globe-list__polaroid-img">
                  <img src={thumbnail} alt={name} width="60" height="45" loading="lazy" decoding="async" />
                </div>
              </div>
            )}
            <div class="globe-list__info">
              <span class="font-display text-sm uppercase tracking-wide text-text group-hover:opacity-60 transition-opacity duration-300">
                {name}
              </span>
              <span class="block text-xs text-secondary mt-0.5">{country}</span>
            </div>
            <div class="flex items-center gap-3 ml-auto">
              <span class="text-xs text-muted">{loc.photoCount} photos</span>
              <span class="text-secondary group-hover:translate-x-1 transition-transform duration-300">&rarr;</span>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</div>

<style>
  .globe-list {
    border-top: 1px solid #E5E5E5;
    max-width: 480px;
    width: 100%;
  }

  .globe-list__item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #E5E5E5;
    text-decoration: none;
    color: inherit;
    /* Rinaldi initial state */
    opacity: 0;
    transform: translateY(80px) skewY(5deg);
    will-change: opacity, transform;
  }

  .globe-list__polaroid {
    flex-shrink: 0;
    background: #fff;
    padding: 3px 3px 8px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    transition: box-shadow 300ms ease, transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .globe-list__item:hover .globe-list__polaroid {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.06);
    transform: rotate(-2deg) scale(1.05);
  }

  .globe-list__polaroid-img {
    width: 42px;
    height: 32px;
    overflow: hidden;
    background: #e0e0e0;
  }

  .globe-list__polaroid-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .globe-list__info {
    min-width: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .globe-list__item {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { animate, inView } from 'motion';
  import { triggerZoomTransition } from '@/utils/globe-transition';

  const POWER4_OUT: [number, number, number, number] = [0.16, 1, 0.3, 1];

  function initGlobeList() {
    const controller = new AbortController();
    const links = document.querySelectorAll<HTMLElement>('[data-globe-loc]');

    // ─── Hover → focus globe ───
    links.forEach(link => {
      link.addEventListener('mouseenter', () => {
        const lat = parseFloat(link.getAttribute('data-lat')!);
        const lng = parseFloat(link.getAttribute('data-lng')!);
        if ((window as any).__cobeGlobeFocus) {
          (window as any).__cobeGlobeFocus(lat, lng);
        }
      }, { signal: controller.signal });

      link.addEventListener('click', (e: Event) => {
        e.preventDefault();
        const lat = parseFloat(link.getAttribute('data-lat')!);
        const lng = parseFloat(link.getAttribute('data-lng')!);
        const href = (link as HTMLAnchorElement).href;
        const slug = link.getAttribute('data-globe-loc') || '';
        const name = link.querySelector('.font-display')?.textContent?.trim() || '';
        const polaroid = (link.querySelector('.globe-list__polaroid') || link) as HTMLElement;
        const rect = polaroid.getBoundingClientRect();
        triggerZoomTransition({
          originX: rect.left + rect.width / 2,
          originY: rect.top + rect.height / 2,
          locationName: name,
          href,
          slug,
          focusLat: lat,
          focusLng: lng,
        });
      }, { signal: controller.signal });
    });

    // ─── Rinaldi reveal — stagger items ───
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      const lists = document.querySelectorAll<HTMLElement>('.globe-list');
      lists.forEach(list => {
        const items = list.querySelectorAll<HTMLElement>('.globe-list__item');
        if (!items.length) return;

        function revealItems() {
          items.forEach((item, i) => {
            animate(
              item,
              { opacity: [0, 1], y: [80, 0], skewY: [5, 0] },
              { duration: 1.2, easing: POWER4_OUT, delay: i * 0.09 }
            );
          });
        }

        // Hero page: synchronise avec l'apparition du bloc globe
        // Autres pages (carte…): inView classique
        if (list.closest('[data-hero-globe-container]')) {
          document.addEventListener('hero:phase-menu-left', revealItems, { once: true });
        } else {
          inView(list, revealItems, { margin: '0px 0px -10% 0px' });
        }
      });
    }

    document.addEventListener('astro:before-swap', () => {
      controller.abort();
    }, { once: true });
  }

  initGlobeList();
  document.addEventListener('astro:page-load', initGlobeList);
</script>
