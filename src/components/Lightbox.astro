---
import { getTranslation, type Lang } from '@/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const t = getTranslation(lang);
---

<div
  id="lightbox"
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label={t('a11y.lightbox.label')}
  aria-hidden="true"
>
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>

  <div class="lightbox-content">
    <img
      id="lightbox-img"
      class="lightbox-image"
      src=""
      alt=""
      draggable="false"
    />
  </div>

  <!-- Counter -->
  <div class="lightbox-counter" id="lightbox-counter"></div>

  <!-- Close -->
  <button
    class="lightbox-btn lightbox-close"
    id="lightbox-close"
    aria-label={t('a11y.lightbox.close')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Previous -->
  <button
    class="lightbox-btn lightbox-prev"
    id="lightbox-prev"
    aria-label={t('a11y.lightbox.prev')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <!-- Next -->
  <button
    class="lightbox-btn lightbox-next"
    id="lightbox-next"
    aria-label={t('a11y.lightbox.next')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;
  }

  .lightbox.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .lightbox.is-open .lightbox-backdrop {
    opacity: 1;
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    transition: opacity 150ms ease;
  }

  .lightbox-btn {
    position: absolute;
    z-index: 2;
    background: none;
    border: none;
    color: #FFFFFF;
    cursor: pointer;
    padding: 12px;
    opacity: 0.6;
    transition: opacity 200ms ease;
  }

  .lightbox-btn:hover {
    opacity: 1;
  }

  .lightbox-close {
    top: 20px;
    right: 20px;
  }

  .lightbox-prev {
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .lightbox-prev {
      left: 8px;
    }

    .lightbox-next {
      right: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox-backdrop,
    .lightbox-image {
      transition: none;
    }
  }
</style>

<script>
  // Module-level controller: aborted on each re-init to remove stale listeners
  let lightboxAbort: AbortController | null = null;

  function initLightbox() {
    // Remove all listeners from the previous page
    lightboxAbort?.abort();
    lightboxAbort = new AbortController();
    const { signal } = lightboxAbort;

    const lightbox = document.getElementById('lightbox');
    const backdrop = document.getElementById('lightbox-backdrop');
    const imgEl = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const counter = document.getElementById('lightbox-counter');

    if (!lightbox || !imgEl) return;

    // Build image list from current page DOM — avoids stale window.__lightboxImages
    const buttons = Array.from(document.querySelectorAll<HTMLElement>('.gallery-image-btn'));
    if (!buttons.length) return;

    const images = buttons
      .sort((a, b) =>
        parseInt(a.dataset.lightboxIndex || '0') - parseInt(b.dataset.lightboxIndex || '0')
      )
      .map(btn => btn.dataset.src || '');

    let currentIndex = 0;
    let previousFocus: HTMLElement | null = null;

    function show(index: number) {
      currentIndex = ((index % images.length) + images.length) % images.length;
      if (counter) counter.textContent = `${currentIndex + 1} / ${images.length}`;

      // Cross-fade: dim → swap → brighten
      imgEl!.style.opacity = '0';
      setTimeout(() => {
        imgEl!.src = images[currentIndex];
        imgEl!.alt = `Image ${currentIndex + 1}`;
        imgEl!.style.opacity = '1';
      }, 150);
    }

    function open(index: number) {
      previousFocus = document.activeElement as HTMLElement;
      currentIndex = ((index % images.length) + images.length) % images.length;
      imgEl!.src = images[currentIndex];
      imgEl!.alt = `Image ${currentIndex + 1}`;
      imgEl!.style.opacity = '1';
      if (counter) counter.textContent = `${currentIndex + 1} / ${images.length}`;
      lightbox!.classList.add('is-open');
      lightbox!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function close() {
      lightbox!.classList.remove('is-open');
      lightbox!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (previousFocus) previousFocus.focus();
    }

    // Gallery image clicks
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        open(parseInt(btn.dataset.lightboxIndex || '0', 10));
      }, { signal });
    });

    // Controls
    closeBtn?.addEventListener('click', close, { signal });
    backdrop?.addEventListener('click', close, { signal });
    prevBtn?.addEventListener('click', () => show(currentIndex - 1), { signal });
    nextBtn?.addEventListener('click', () => show(currentIndex + 1), { signal });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox!.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(currentIndex - 1);
      if (e.key === 'ArrowRight') show(currentIndex + 1);
    }, { signal });

    // Touch swipe (horizontal)
    let touchStartX = 0;
    lightbox!.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { signal, passive: true });
    lightbox!.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) {
        if (dx < 0) show(currentIndex + 1); // swipe left → next
        else show(currentIndex - 1);         // swipe right → prev
      }
    }, { signal });

    // Focus trap
    lightbox!.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = lightbox!.querySelectorAll<HTMLElement>('button:not([disabled])');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }, { signal });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
