---
import type { GalleryImage } from '@/data/gallery-loader';
import { getTranslation, type Lang } from '@/i18n';

interface Props {
  images: GalleryImage[];
  lang?: Lang;
}

const { images, lang = 'fr' } = Astro.props;
const t = getTranslation(lang);
---

<div
  id="lightbox"
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label={t('a11y.lightbox.label')}
  aria-hidden="true"
>
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>

  <div class="lightbox-content">
    <img
      id="lightbox-img"
      class="lightbox-image"
      src=""
      alt=""
      draggable="false"
    />
  </div>

  <!-- Counter -->
  <div class="lightbox-counter" id="lightbox-counter"></div>

  <!-- Close -->
  <button
    class="lightbox-btn lightbox-close"
    id="lightbox-close"
    aria-label={t('a11y.lightbox.close')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Previous -->
  <button
    class="lightbox-btn lightbox-prev"
    id="lightbox-prev"
    aria-label={t('a11y.lightbox.prev')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <!-- Next -->
  <button
    class="lightbox-btn lightbox-next"
    id="lightbox-next"
    aria-label={t('a11y.lightbox.next')}
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
</div>

<!-- Image data for JS -->
<script is:inline define:vars={{ images }}>
  window.__lightboxImages = images;
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;
  }

  .lightbox.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .lightbox.is-open .lightbox-backdrop {
    opacity: 1;
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .lightbox.is-open .lightbox-image {
    opacity: 1;
  }

  .lightbox-btn {
    position: absolute;
    z-index: 2;
    background: none;
    border: none;
    color: #FFFFFF;
    cursor: pointer;
    padding: 12px;
    opacity: 0.6;
    transition: opacity 200ms ease;
  }

  .lightbox-btn:hover {
    opacity: 1;
  }

  .lightbox-close {
    top: 20px;
    right: 20px;
  }

  .lightbox-prev {
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .lightbox-prev {
      left: 8px;
    }

    .lightbox-next {
      right: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox-backdrop,
    .lightbox-image {
      transition: none;
    }
  }
</style>

<script>
  function initLightbox() {
    const lightbox = document.getElementById('lightbox');
    const backdrop = document.getElementById('lightbox-backdrop');
    const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const counter = document.getElementById('lightbox-counter');

    if (!lightbox || !img) return;

    const images = (window as any).__lightboxImages as Array<{ src: string; width: number; height: number }>;
    if (!images?.length) return;

    let currentIndex = 0;
    let previousFocus: HTMLElement | null = null;

    function show(index: number) {
      currentIndex = ((index % images.length) + images.length) % images.length;
      const image = images[currentIndex];
      img!.src = image.src;
      img!.alt = `Image ${currentIndex + 1}`;
      if (counter) counter.textContent = `${currentIndex + 1} / ${images.length}`;
    }

    function open(index: number) {
      previousFocus = document.activeElement as HTMLElement;
      show(index);
      lightbox!.classList.add('is-open');
      lightbox!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function close() {
      lightbox!.classList.remove('is-open');
      lightbox!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (previousFocus) previousFocus.focus();
    }

    // Open on gallery image click
    document.querySelectorAll('.gallery-image-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const index = parseInt((btn as HTMLElement).dataset.lightboxIndex || '0', 10);
        open(index);
      });
    });

    // Controls
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    prevBtn?.addEventListener('click', () => show(currentIndex - 1));
    nextBtn?.addEventListener('click', () => show(currentIndex + 1));

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!lightbox!.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(currentIndex - 1);
      if (e.key === 'ArrowRight') show(currentIndex + 1);
    });

    // Focus trap
    lightbox!.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = lightbox!.querySelectorAll<HTMLElement>('button:not([disabled])');
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
