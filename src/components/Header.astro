---
import { getLangFromUrl, getTranslation, getLocalizedPath } from '@/i18n';
import LanguageToggle from './LanguageToggle.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  alternateHref?: string;
}

const { alternateHref } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = getTranslation(lang);
const currentPath = Astro.url.pathname;
const homePath = getLocalizedPath(lang, '/');

const locationLinks = [
  { label: t('nav.location.bresil'), href: getLocalizedPath(lang, '/works/bresil/') },
  { label: t('nav.location.dakar'), href: getLocalizedPath(lang, '/works/dakar/') },
  { label: t('nav.location.saint-tropez'), href: getLocalizedPath(lang, '/works/saint-tropez/') },
  { label: t('nav.location.reunion'), href: getLocalizedPath(lang, '/works/reunion/') },
  { label: t('nav.location.sri-lanka'), href: getLocalizedPath(lang, '/works/sri-lanka/') },
  { label: t('nav.location.costa-rica'), href: getLocalizedPath(lang, '/works/costa-rica/') },
];

const pageLinks = [
  { label: t('nav.series'), href: getLocalizedPath(lang, '/series/') },
  { label: t('nav.exhibitions'), href: getLocalizedPath(lang, '/exhibitions/') },
  { label: t('nav.press'), href: getLocalizedPath(lang, '/press/') },
  { label: t('nav.about'), href: getLocalizedPath(lang, '/about/') },
  { label: t('nav.contact'), href: getLocalizedPath(lang, '/contact/') },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-hover ease-ease"
>
  <div class="mx-auto w-full max-w-container px-gutter-sm md:px-gutter-md lg:px-gutter-lg flex items-center justify-between h-16 lg:h-20">
    <!-- Left: Location links (desktop only) -->
    <nav class="hidden lg:flex items-center gap-5" aria-label="Locations">
      {locationLinks.map(({ label, href }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              'header-nav-link text-xs uppercase tracking-widest font-sans',
              isActive ? 'text-text' : 'text-secondary hover:text-text',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Center: SC monogram -->
    <a
      href={homePath}
      class="font-serif text-xl font-light text-text lg:absolute lg:left-1/2 lg:-translate-x-1/2"
    >
      SC
    </a>

    <!-- Right: Page links + Language toggle (desktop only) -->
    <nav class="hidden lg:flex items-center gap-5" aria-label={t('a11y.main_nav')}>
      {pageLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              'header-nav-link text-xs uppercase tracking-widest font-sans',
              isActive ? 'text-text' : 'text-secondary hover:text-text',
            ]}
          >
            {label}
          </a>
        );
      })}
      <LanguageToggle alternateHref={alternateHref} />
    </nav>

    <!-- Mobile: Hamburger button -->
    <button
      id="menu-toggle"
      class="lg:hidden relative w-10 h-10 flex items-center justify-center z-[110]"
      aria-label={t('a11y.menu_open')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line hamburger-line--top"></span>
      <span class="hamburger-line hamburger-line--bottom"></span>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<MobileMenu lang={lang} alternateHref={alternateHref} />

<style>
  /* Animated underline on hover */
  .header-nav-link {
    position: relative;
    transition: color 300ms ease;
  }

  .header-nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: currentColor;
    transition: width 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .header-nav-link:hover::after {
    width: 100%;
  }

  /* Hamburger lines */
  .hamburger-line {
    position: absolute;
    width: 22px;
    height: 1.5px;
    background-color: #1A1A1A;
    transition: transform 500ms cubic-bezier(0.76, 0, 0.24, 1),
                opacity 300ms ease;
  }

  .hamburger-line--top {
    transform: translateY(-4px);
  }

  .hamburger-line--bottom {
    transform: translateY(4px);
  }

  /* Morphed to X */
  .menu-open .hamburger-line--top {
    transform: translateY(0) rotate(45deg);
  }

  .menu-open .hamburger-line--bottom {
    transform: translateY(0) rotate(-45deg);
  }

  /* Header scroll state */
  #site-header.is-scrolled {
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #E5E5E5;
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-line {
      transition: transform 200ms ease;
    }

    .header-nav-link::after {
      transition: none;
    }
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const menuToggle = document.getElementById('menu-toggle');
    let menuIsOpen = false;

    // Scroll detection
    function handleScroll() {
      if (!header || menuIsOpen) return;
      if (window.scrollY > 50) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Hamburger toggle
    menuToggle?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('mobile-menu:toggle'));
    });

    // Listen for menu state changes
    document.addEventListener('mobile-menu:opened', () => {
      menuIsOpen = true;
      menuToggle?.classList.add('menu-open');
      menuToggle?.setAttribute('aria-expanded', 'true');
      header?.classList.remove('is-scrolled');
    });

    document.addEventListener('mobile-menu:closed', () => {
      menuIsOpen = false;
      menuToggle?.classList.remove('menu-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
      handleScroll();
    });
  }

  initHeader();

  document.addEventListener('astro:page-load', () => {
    initHeader();
  });
</script>
