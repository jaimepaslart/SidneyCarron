---
import { getLangFromUrl, getTranslation, getLocalizedPath } from '@/i18n';
import { locations } from '@/data/locations';
import LanguageToggle from './LanguageToggle.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  alternateHref?: string;
  variant?: 'page' | 'hero';
}

const { alternateHref, variant = 'page' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = getTranslation(lang);
const currentPath = Astro.url.pathname;
const homePath = getLocalizedPath(lang, '/');
const cartePath = getLocalizedPath(lang, lang === 'fr' ? '/carte/' : '/carte/');

const locationLinks = [
  { label: t('nav.carte'), href: getLocalizedPath(lang, lang === 'fr' ? '/carte/' : '/carte/'), isHighlight: true },
  ...locations.map(loc => ({
    label: t(`nav.location.${loc.slug}` as any),
    href: getLocalizedPath(lang, `/works/${loc.slug}/`),
    isHighlight: false,
  })),
];

const pageLinks = [
  { label: t('nav.exhibitions'), href: getLocalizedPath(lang, '/exhibitions/') },
  { label: t('nav.press'), href: getLocalizedPath(lang, '/press/') },
  { label: t('nav.about'), href: getLocalizedPath(lang, '/about/') },
  { label: t('nav.contact'), href: getLocalizedPath(lang, '/contact/') },
];

const isHero = variant === 'hero';
---

<!-- Same layout everywhere: vertical stacked nav, centered SiD logo -->
<header id="site-header" class="w-full px-5 md:px-8 lg:px-[7.5%] pt-[4vh] lg:pt-[12vh]" data-variant={variant}>
  <nav class="flex justify-between items-center lg:items-start relative min-h-[70px] lg:min-h-0">
    <!-- Mobile: Hamburger button LEFT -->
    <button
      id="menu-toggle"
      class:list={['burger lg:hidden z-[110] order-first', { 'burger-hero': isHero }]}
      aria-label={t('a11y.menu_open')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <!-- Left: Locations (stacked vertically, desktop only) -->
    <ul class="hidden lg:block hero-menu-left" aria-label="Locations">
      {locationLinks.map(({ label, href, isHighlight }, i) => {
        const isActive = currentPath.startsWith(href);
        return (
          <li
            class:list={['hero-nav-item', { 'no-anim': !isHero }]}
            style={`--stagger: ${i}`}
          >
            <a
              href={href}
              class:list={[
                'header-nav-link font-sans text-base font-normal uppercase leading-6 block',
                isHighlight ? 'font-medium' : '',
                isActive ? 'text-text' : 'text-text hover:opacity-60',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Center: SiD stamp logo -->
    <a
      href={homePath}
      id="hero-monogram"
      class:list={['hero-monogram absolute left-1/2 -translate-x-1/2 top-0 lg:top-1/2 lg:-translate-y-1/2', { 'no-anim': !isHero }]}
    >
      <img src="/images/sid-logo.svg" alt="Sidney Carron" class="h-[70px] lg:h-[100px] w-auto" />
    </a>

    <!-- Right: Pages + Language toggle (stacked vertically, desktop only) -->
    <ul class="hidden lg:block text-right hero-menu-right" aria-label={t('a11y.main_nav')}>
      {pageLinks.map(({ label, href }, i) => {
        const isActive = currentPath === href || currentPath.startsWith(href);
        return (
          <li
            class:list={['hero-nav-item', { 'no-anim': !isHero }]}
            style={`--stagger: ${i}`}
          >
            <a
              href={href}
              class:list={[
                'header-nav-link font-sans text-base font-normal uppercase leading-6 block',
                isActive ? 'text-text' : 'text-text hover:opacity-60',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
      <li
        class:list={['hero-nav-item mt-1', { 'no-anim': !isHero }]}
        style={`--stagger: ${pageLinks.length}`}
      >
        <LanguageToggle alternateHref={alternateHref} />
      </li>
    </ul>
  </nav>
</header>

<!-- Mobile menu overlay -->
<MobileMenu lang={lang} alternateHref={alternateHref} />

<style>
  /* === Monogram: gentle fade-up (hero only) === */
  .hero-monogram img {
    opacity: 0;
    transform: translateY(25px);
    transition: opacity 1.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-monogram.is-revealed img,
  .hero-monogram.no-anim img {
    opacity: 1;
    transform: translateY(0);
  }

  /* No-anim: skip transition, show immediately */
  .hero-monogram.no-anim img {
    transition: none;
  }

  /* === Nav items: staggered fade-up (hero) or visible (page) === */
  .hero-nav-item {
    opacity: 0;
    transform: translateY(12px);
  }

  .hero-nav-item.is-revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.9s cubic-bezier(0.165, 0.84, 0.44, 1),
                transform 0.9s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* Page variant: visible immediately, no animation */
  .hero-nav-item.no-anim {
    opacity: 1;
    transform: none;
  }

  /* Animated underline on hover */
  .header-nav-link {
    position: relative;
    transition: color 300ms ease, opacity 300ms ease;
  }

  .header-nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: currentColor;
    transition: width 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .header-nav-link:hover::after {
    width: 100%;
  }

  /* Burger — Rinaldi style (hidden on lg via Tailwind lg:hidden) */
  .burger {
    width: 36px;
    height: 22px;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    position: relative;
    background: none;
    border: none;
    padding: 0;
  }

  @media (max-width: 1023px) {
    .burger {
      display: flex;
    }
  }

  .burger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #1A1A1A;
    border-radius: 1px;
    transition: transform 0.45s cubic-bezier(0.76, 0, 0.24, 1),
                width 0.45s cubic-bezier(0.76, 0, 0.24, 1);
    transform-origin: center;
  }

  .menu-open .burger-line:first-child {
    transform: translateY(10px) rotate(45deg);
  }

  .menu-open .burger-line:last-child {
    transform: translateY(-10px) rotate(-45deg);
  }

  /* Burger entrance animation on hero: lines draw left-to-right (Rinaldi style) */
  .burger-hero .burger-line {
    width: 0;
  }

  .burger-hero.is-revealed .burger-line {
    width: 100%;
    transition: width 1.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .burger-hero.is-revealed .burger-line:last-child {
    transition-delay: 0.15s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-monogram img {
      opacity: 1;
      transform: none;
    }

    .hero-nav-item {
      opacity: 1;
      transform: none;
    }

    .burger-line {
      transition: transform 200ms ease;
    }

    .header-nav-link::after {
      transition: none;
    }
  }
</style>

<script>
  let headerAbort: AbortController | null = null;

  function initHeader() {
    // Clean up previous listeners to prevent duplicates
    if (headerAbort) headerAbort.abort();
    headerAbort = new AbortController();
    const signal = headerAbort.signal;

    const header = document.getElementById('site-header');
    const menuToggle = document.getElementById('menu-toggle');
    if (!header) return;

    const isHeroVariant = header.dataset.variant === 'hero';

    // === Hero sequence listeners (only on homepage) ===
    const monogram = document.getElementById('hero-monogram');
    const leftItems = header.querySelectorAll('.hero-menu-left .hero-nav-item');
    const rightItems = header.querySelectorAll('.hero-menu-right .hero-nav-item');

    if (monogram && isHeroVariant) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        monogram.classList.add('is-revealed');
        menuToggle?.classList.add('is-revealed');
        leftItems.forEach((el) => el.classList.add('is-revealed'));
        rightItems.forEach((el) => el.classList.add('is-revealed'));
      } else {
        // Phase 1: Logo + burger fade-up
        document.addEventListener('hero:phase-logo', () => {
          monogram.classList.add('is-revealed');
          menuToggle?.classList.add('is-revealed');
        }, { once: true, signal });

        function revealMenuItems(items: NodeListOf<Element>): void {
          items.forEach((item) => {
            const el = item as HTMLElement;
            const stagger = parseInt(el.style.getPropertyValue('--stagger') || '0', 10);
            setTimeout(() => el.classList.add('is-revealed'), stagger * 80);
          });
        }

        document.addEventListener('hero:phase-menu-left', () => revealMenuItems(leftItems), { once: true, signal });
        document.addEventListener('hero:phase-menu-right', () => revealMenuItems(rightItems), { once: true, signal });
      }
    }

    // === Hamburger toggle ===
    menuToggle?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('mobile-menu:toggle'));
    }, { signal });

    document.addEventListener('mobile-menu:opened', () => {
      menuToggle?.classList.add('menu-open');
      menuToggle?.setAttribute('aria-expanded', 'true');
    }, { signal });

    document.addEventListener('mobile-menu:closed', () => {
      menuToggle?.classList.remove('menu-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
    }, { signal });
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
