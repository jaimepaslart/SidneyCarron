---
import { getLangFromUrl, getLocalizedPath } from '@/i18n';

interface WorkImage {
  src: string;
  alt: string;
}

interface Props {
  slug: string;
  title: string;
  year: number;
  medium: string;
  image: WorkImage;
  class?: string;
}

const { slug, title, year, medium, image, class: className = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const href = getLocalizedPath(lang, `/works/${slug}`);
---

<a href={href} class={`group block ${className}`} data-work-card>
  <div class="relative overflow-hidden bg-[#F5F5F5]">
    <img
      src={image.src}
      alt={image.alt}
      width="600"
      height="800"
      loading="lazy"
      class="w-full h-auto object-cover transition-transform duration-hover ease"
      style="transition-duration: 300ms;"
    />
    <!-- Hover overlay (desktop only) -->
    <div class="hidden md:flex absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity duration-hover ease items-center justify-center flex-col text-center p-4" style="transition-duration: 300ms;">
      <span class="font-serif text-white text-xl lg:text-2xl font-light">{title}</span>
      <span class="font-sans text-white/80 text-sm mt-2">{year} — {medium}</span>
    </div>
  </div>
  <!-- Mobile: title + year below image -->
  <div class="md:hidden mt-3">
    <p class="font-serif text-base text-text">{title}</p>
    <p class="font-sans text-sm text-secondary mt-1">{year}</p>
  </div>
</a>

<style>
  [data-work-card]:hover img {
    transform: scale(1.02);
  }
</style>
