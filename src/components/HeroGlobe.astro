---
import CobeGlobe from './CobeGlobe.astro';
import GlobeLocationList from './GlobeLocationList.astro';
import type { Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="hero__globe" data-hero-globe-container>
  <div class="hero__globe-grid">

    <!-- Globe centré dans sa colonne -->
    <div class="hero__globe-sphere">
      <CobeGlobe lang={lang} showPins={true} rotationSpeed={0.004} maxWidth="min(88vw, 600px)" heroMode={true} />
    </div>

    <!-- Liste des lieux — visible sur tous les breakpoints -->
    <div class="hero__globe-list">
      <GlobeLocationList lang={lang} />
    </div>

  </div>
</div>

<style>
  .hero__globe {
    width: 100%;
    margin-top: 2rem;
    padding: 0 1.25rem;
    opacity: 0;
    transform: translateY(50px);
  }

  .hero__globe--revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1.2s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* Mobile : colonne — globe en haut, liste en bas */
  .hero__globe-grid {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Globe centré dans sa colonne */
  .hero__globe-sphere {
    display: flex;
    justify-content: center;
  }

  .hero__globe-sphere :global(.cobe-globe) {
    width: 100%;
  }

  .hero__globe-sphere :global(.cobe-globe__sphere) {
    margin: 0 auto;
  }

  /* Override hidden md:block du GlobeLocationList pour mobile */
  .hero__globe-list > :global(div) {
    display: block;
  }

  /* Desktop (≥ 768px) : 2 colonnes — globe | liste */
  @media (min-width: 768px) {
    .hero__globe {
      margin-top: 3rem;
      padding: 0 2rem;
    }

    .hero__globe-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    /* Contraindre le globe à la largeur de sa colonne */
    .hero__globe-sphere :global(.cobe-globe__sphere) {
      max-width: min(44vw, 600px);
    }
  }

  /* Grand écran (≥ 1024px) : hauteur fixe, globe plus grand */
  @media (min-width: 1024px) {
    .hero__globe {
      height: 80vh;
      min-height: 500px;
      margin-top: 3rem;
      padding: 0 3rem;
      display: flex;
      align-items: center;
    }

    .hero__globe-grid {
      width: 100%;
      height: 100%;
    }

    .hero__globe-sphere {
      height: 100%;
      align-items: center;
    }

    .hero__globe-sphere :global(.cobe-globe__sphere) {
      max-width: min(42vw, 700px);
    }

    .hero__globe-list {
      height: 100%;
      overflow-y: auto;
      display: flex;
      align-items: center;
    }

    .hero__globe-list > :global(div) {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__globe {
      opacity: 1;
      transform: none;
    }
  }
</style>
