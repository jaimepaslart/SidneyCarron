---
import CobeGlobe from './CobeGlobe.astro';
import GlobeLocationList from './GlobeLocationList.astro';
import type { Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="hero__globe" data-hero-globe-container>
  <div class="hero__globe-grid">

    <!-- Liste des lieux — colonne gauche sur desktop -->
    <div class="hero__globe-list">
      <GlobeLocationList lang={lang} />
    </div>

    <!-- Globe — colonne droite sur desktop -->
    <div class="hero__globe-sphere">
      <CobeGlobe lang={lang} showPins={true} rotationSpeed={0.004} heroMode={true} />
    </div>

  </div>
</div>

<style>
  .hero__globe {
    width: 100%;
    margin-top: 2rem;
    padding: 0 1.25rem 3rem;
    opacity: 0;
    transform: translateY(50px);
  }

  .hero__globe--revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1.2s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* Mobile : liste d'abord, globe ensuite */
  .hero__globe-grid {
    display: flex;
    flex-direction: column-reverse;
    gap: 2.5rem;
  }

  /* Globe centré sur mobile */
  .hero__globe-sphere {
    display: flex;
    justify-content: center;
  }

  .hero__globe-sphere :global(.cobe-globe) {
    width: 100%;
  }

  .hero__globe-sphere :global(.cobe-globe__sphere) {
    max-width: min(86vw, 380px);
    margin: 0 auto;
  }

  /* Override hidden md:block du GlobeLocationList pour mobile */
  .hero__globe-list > :global(div) {
    display: block;
  }

  /* Desktop (≥ 768px) : 2 colonnes égales — liste | globe */
  @media (min-width: 768px) {
    .hero__globe {
      margin-top: 3rem;
      padding: 0 2rem 3rem;
    }

    .hero__globe-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero__globe-sphere :global(.cobe-globe__sphere) {
      max-width: min(52vw, 480px);
      margin: 0 auto;
    }
  }

  /* Grand écran (≥ 1024px) — aligne avec expo-section */
  @media (min-width: 1024px) {
    .hero__globe {
      margin-top: 7rem;
      padding: 0 7.5% 5rem;
    }

    .hero__globe-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero__globe-sphere :global(.cobe-globe__sphere) {
      max-width: 540px;
    }

    .hero__globe-list {
      display: flex;
      align-items: center;
    }

    .hero__globe-list > :global(div) {
      width: 100%;
    }

    /* La liste remplit sa colonne comme la liste expo — supprime le plafond 480px */
    .hero__globe-list :global(.globe-list) {
      max-width: none;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__globe {
      opacity: 1;
      transform: none;
    }
  }
</style>
