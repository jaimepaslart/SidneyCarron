---
import TextReveal from './TextReveal.astro';
import Header from './Header.astro';
import { getSettings } from '@/utils/site';

interface Props {
  lang: 'fr' | 'en';
  alternateHref?: string;
}

const { lang, alternateHref } = Astro.props;
const settings = getSettings();
const nameParts = settings.artistName.toUpperCase().split(' ');
---

<section class="hero" id="hero-section">
  <!-- Header -->
  <Header variant="hero" alternateHref={alternateHref} />

  <!-- Artist name -->
  <h1 class="hero__title" style="perspective: 600px;">
    <TextReveal
      text={nameParts[0]}
      tag="span"
      class="block font-display font-medium uppercase leading-[0.924] text-[clamp(2.75rem,13vw,160px)] text-text"
      heroSequence={true}
    />
    <TextReveal
      text={nameParts[1] || ''}
      tag="span"
      class="block font-display font-medium uppercase leading-[0.924] text-[clamp(2.75rem,13vw,160px)] text-text"
      heroSequence={true}
      heroDelay={280}
    />
  </h1>

  <!-- Hero image — full-width edge-to-edge, parallax via Motion -->
  <div class="hero__image" data-hero-image>
    <img
      src={settings.heroImage}
      alt={`${settings.artistName} — Artiste photographe`}
      class="hero__image-src"
      data-hero-parallax
      loading="eager"
      decoding="async"
      width="1920"
      height="1080"
    />
  </div>
</section>

<style>
  /* ============================================
     Block: .hero
     Hero section — full viewport intro
     ============================================ */
  .hero {
    position: relative;
    background-color: #FFFFFF;
  }

  /* Element: .hero__title */
  .hero__title {
    text-align: center;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .hero__title {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__title {
      margin-top: 90px;
    }
  }

  /* Element: .hero__image — parallax container */
  .hero__image {
    width: 100%;
    margin-top: 3rem;
    opacity: 0;
    transform: translateY(50px);
  }

  @media (min-width: 768px) {
    .hero__image {
      margin-top: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__image {
      height: 70vh;
      min-height: 400px;
      margin-top: 3rem;
      overflow: hidden;
    }
  }

  /* Modifier: revealed state */
  .hero__image--revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1.2s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* Element: .hero__image-src — the actual img */
  .hero__image-src {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 1024px) {
    .hero__image-src {
      height: 140%;
      object-fit: cover;
      object-position: center;
      will-change: transform;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__image {
      opacity: 1;
      transform: none;
    }

    .hero__image-src {
      height: 100%;
    }
  }
</style>

<script>
  import { animate, scroll } from 'motion';

  /**
   * Hero — Intro orchestrator + Parallax
   *
   * BEM selectors:
   *   [data-hero-image]    → .hero__image container
   *   [data-hero-parallax] → .hero__image-src (parallaxed img)
   *
   * Intro sequence (desktop):
   *   Phase 1 (0ms):    Logo fades in
   *   Phase 2 (400ms):  Artist name reveals char-by-char
   *   Phase 3 (900ms):  Left menu staggers + image fades up
   *   Phase 4 (1500ms): Right menu staggers in
   */

  const SELECTORS = {
    image: '[data-hero-image]',
    parallax: '[data-hero-parallax]',
  } as const;

  const CLASSES = {
    imageRevealed: 'hero__image--revealed',
  } as const;

  function initHeroIntro(): void {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const imageEl = document.querySelector<HTMLElement>(SELECTORS.image);
    const isMobile = window.innerWidth < 1024;

    if (prefersReduced) {
      setTimeout(() => {
        imageEl?.classList.add(CLASSES.imageRevealed);
        document.dispatchEvent(new CustomEvent('hero:phase-logo'));
        document.dispatchEvent(new CustomEvent('hero:phase-name'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-right'));
      }, 0);
      return;
    }

    if (isMobile) {
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-logo')), 0);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-name')), 300);
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-right'));
        imageEl?.classList.add(CLASSES.imageRevealed);
      }, 800);
    } else {
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-logo')), 0);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-name')), 400);
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        imageEl?.classList.add(CLASSES.imageRevealed);
      }, 900);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-menu-right')), 1500);
    }
  }

  function initHeroParallax(): void {
    const imgEl = document.querySelector<HTMLElement>(SELECTORS.parallax);
    const containerEl = document.querySelector<HTMLElement>(SELECTORS.image);
    if (!imgEl || !containerEl) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    scroll(
      animate(imgEl, { y: ['0%', '-25%'] }, { ease: 'linear' }),
      {
        target: containerEl,
        offset: ['start end', 'end start'],
      }
    );
  }

  function initHero(): void {
    initHeroIntro();
    initHeroParallax();
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
