---
import TextReveal from './TextReveal.astro';
import Header from './Header.astro';
import HeroGlobe from './HeroGlobe.astro';
import { getSettings } from '@/utils/site';

interface Props {
  lang: 'fr' | 'en';
  alternateHref?: string;
}

const { lang, alternateHref } = Astro.props;
const settings = getSettings();
const nameParts = settings.artistName.toUpperCase().split(' ');
---

<section class="hero" id="hero-section">
  <!-- Header -->
  <Header variant="hero" alternateHref={alternateHref} />

  <!-- Artist name -->
  <h1 class="hero__title" style="perspective: 600px;">
    <TextReveal
      text={nameParts[0]}
      tag="span"
      class="block font-display font-medium uppercase leading-[0.924] text-[clamp(2.75rem,13vw,160px)] text-text"
      heroSequence={true}
    />
    <TextReveal
      text={nameParts[1] || ''}
      tag="span"
      class="block font-display font-medium uppercase leading-[0.924] text-[clamp(2.75rem,13vw,160px)] text-text"
      heroSequence={true}
      heroDelay={280}
    />
  </h1>

  <!-- Globe interactif — remplace l'image hero -->
  <HeroGlobe lang={lang} />
</section>

<style>
  /* ============================================
     Block: .hero
     Hero section — full viewport intro
     ============================================ */
  .hero {
    position: relative;
    background-color: #FFFFFF;
  }

  /* Element: .hero__title */
  .hero__title {
    text-align: center;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .hero__title {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__title {
      margin-top: 90px;
    }
  }



  /* Hero globe reveal handled by HeroGlobe.astro */
</style>

<script>
  /**
   * Hero — Intro orchestrator
   *
   * BEM selectors:
   *   [data-hero-globe-container] → .hero__globe container (HeroGlobe.astro)
   *
   * Intro sequence (desktop):
   *   Phase 1 (0ms):    Logo fades in
   *   Phase 2 (400ms):  Artist name reveals char-by-char
   *   Phase 3 (900ms):  Left menu staggers + globe fades up
   *   Phase 4 (1500ms): Right menu staggers in
   */

  const SELECTORS = {
    image: '[data-hero-globe-container]',
  } as const;

  const CLASSES = {
    imageRevealed: 'hero__globe--revealed',
  } as const;

  function initHeroIntro(): void {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const imageEl = document.querySelector<HTMLElement>(SELECTORS.image);
    const isMobile = window.innerWidth < 1024;

    // Defer all dispatches by one tick so all module listeners (Header, TextReveal)
    // are guaranteed to be registered before any event fires.
    if (prefersReduced) {
      setTimeout(() => {
        imageEl?.classList.add(CLASSES.imageRevealed);
        document.dispatchEvent(new CustomEvent('hero:phase-logo'));
        document.dispatchEvent(new CustomEvent('hero:phase-name'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-right'));
      }, 0);
      return;
    }

    if (isMobile) {
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-logo')), 0);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-name')), 300);
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        document.dispatchEvent(new CustomEvent('hero:phase-menu-right'));
        imageEl?.classList.add(CLASSES.imageRevealed);
      }, 800);
    } else {
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-logo')), 0);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-name')), 400);
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('hero:phase-menu-left'));
        imageEl?.classList.add(CLASSES.imageRevealed);
      }, 900);
      setTimeout(() => document.dispatchEvent(new CustomEvent('hero:phase-menu-right')), 1500);
    }
  }

  function initHero(): void {
    initHeroIntro();
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
