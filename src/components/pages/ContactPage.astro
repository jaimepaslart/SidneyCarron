---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getTranslation, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      name: t('contact.title'),
      description: t('contact.description'),
      url: `${siteUrl}/${lang === 'en' ? 'en/' : ''}contact`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: t('contact.title') },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('contact.title')} — Sidney Carron`}
  description={t('contact.description')}
  canonicalPath="/contact"
  jsonLd={jsonLd}
>
  <section class="min-h-[60vh] flex items-center">
    <div class="museum-container max-w-2xl mx-auto text-center py-section-sm md:py-section-md lg:py-section-lg">
      <ScrollReveal>
        <h1 class="font-serif font-light text-4xl text-text">{t('contact.title')}</h1>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <p class="font-serif text-lg text-text mt-6 leading-relaxed">
          {t('contact.intro')}
        </p>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="mt-10">
          <a
            href="mailto:contact@sidneycarron.com"
            class="font-serif text-xl text-text hover:text-hover transition-colors duration-hover ease"
          >
            contact@sidneycarron.com
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="mt-6">
          <a
            href="https://instagram.com/sidneycarron"
            target="_blank"
            rel="noopener noreferrer"
            class="font-sans text-base text-secondary hover:text-text transition-colors duration-hover ease"
          >
            Instagram
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>
</PageLayout>
