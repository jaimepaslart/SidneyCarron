---
import PageLayout from '@/layouts/PageLayout.astro';
import PressItem from '@/components/PressItem.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const allPress = await getCollection('press');
const articles = allPress.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: t('press.title'),
      description: t('press.description'),
      url: `${siteUrl}${getLocalizedPath(lang, '/press')}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: t('press.title') },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('press.title')} — Sidney Carron`}
  description={t('press.description')}
  canonicalPath="/press"
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container max-w-4xl">
      <ScrollReveal>
        <h1 class="font-sans font-light text-4xl text-text mb-8 md:mb-12">
          {t('press.title')}
        </h1>
      </ScrollReveal>

      <div class="divide-y divide-border">
        {articles.map((article, i) => (
          <ScrollReveal delay={i * 80}>
            <PressItem
              article={{
                title: lang === 'en' ? article.data.title_en : article.data.title_fr,
                publication: article.data.publication,
                date: article.data.date,
                excerpt: lang === 'en' ? article.data.excerpt_en : article.data.excerpt_fr,
                url: article.data.url,
                pdf: article.data.pdf,
              }}
              lang={lang}
            />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
