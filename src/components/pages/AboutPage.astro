---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';
import { getAbout, getSettings, localize, SITE_URL } from '@/utils/site';
import { buildPersonSchema, buildBreadcrumbs } from '@/utils/seo';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const aboutData = getAbout();
const settings = getSettings();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    buildPersonSchema(lang),
    buildBreadcrumbs([{ name: localize(lang, 'À propos', 'About') }]),
  ],
};

const bio = {
  title: localize(lang, 'À propos de Sidney Carron', 'About Sidney Carron'),
  intro: localize(lang, aboutData.intro_fr, aboutData.intro_en),
  bioTitle: localize(lang, 'Biographie', 'Biography'),
  bioText: localize(lang, aboutData.bio_fr, aboutData.bio_en),
  statement: localize(lang, aboutData.statement_fr, aboutData.statement_en),
  cvTitle: localize(lang, 'Parcours', 'Career'),
  cvItems: aboutData.cv.map(item => ({
    year: item.year,
    text: localize(lang, item.text_fr, item.text_en),
  })),
};

const downloads = [
  { href: aboutData.pdf_bio, label: t('about.download_bio') },
  { href: aboutData.pdf_exhibitions, label: t('about.download_exhibitions') },
  { href: aboutData.pdf_poem, label: t('about.download_poem') },
].filter(d => d.href);
---

<PageLayout
  title={`${t('about.title')} — Sidney Carron`}
  description={t('about.description')}
  ogImage={aboutData.portrait}
  canonicalPath="/about"
  jsonLd={jsonLd}
>
  <!-- 1. Split portrait/intro -->
  <section class="museum-section">
    <div class="museum-container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-16">
        <!-- Portrait (40%) -->
        <div class="lg:col-span-2">
          <ScrollReveal>
            <div class="overflow-hidden bg-surface">
              <img
                src={aboutData.portrait}
                alt={lang === 'fr' ? 'Portrait de Sidney Carron' : 'Portrait of Sidney Carron'}
                width="600"
                height="800"
                loading="eager"
                class="w-full h-auto object-cover"
              />
            </div>
          </ScrollReveal>
        </div>

        <!-- Intro (60%) -->
        <div class="lg:col-span-3 flex flex-col justify-center">
          <ScrollReveal delay={100}>
            <h1 class="font-sans font-light text-4xl text-text">{bio.title}</h1>
            <p class="font-sans text-lg text-text mt-6 leading-relaxed">{bio.intro}</p>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Biography -->
  <section class="museum-section border-t border-border">
    <div class="museum-container max-w-3xl">
      <ScrollReveal>
        <h2 class="font-sans font-light text-2xl text-text mb-6">{bio.bioTitle}</h2>
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <div class="font-sans text-base text-text leading-relaxed space-y-4">
          {bio.bioText.split('\n\n').map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- 3. Artistic statement -->
  <section class="museum-section border-t border-border">
    <div class="museum-container">
      <ScrollReveal>
        <blockquote class="font-sans italic text-2xl md:text-3xl text-center max-w-3xl mx-auto text-text leading-relaxed">
          {bio.statement}
        </blockquote>
      </ScrollReveal>
    </div>
  </section>

  <!-- 4. Downloads -->
  <section class="museum-section border-t border-border">
    <div class="museum-container max-w-3xl">
      <ScrollReveal>
        <h2 class="font-sans font-light text-2xl text-text mb-6">{t('about.downloads')}</h2>
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <div class="flex flex-wrap gap-4">
          {downloads.map(({ href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-3 border border-border text-sm text-text hover:bg-surface transition-colors duration-300"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {label}
            </a>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- 5. CV / Timeline -->
  <section class="museum-section border-t border-border">
    <div class="museum-container max-w-3xl">
      <ScrollReveal>
        <h2 class="font-sans font-light text-2xl text-text mb-8">{bio.cvTitle}</h2>
      </ScrollReveal>
      <div class="relative border-l-2 border-border pl-8 ml-1.5 space-y-0">
        {bio.cvItems.map(({ year, text }, i) => (
          <ScrollReveal delay={i * 80}>
            <div class="relative py-4 border-b border-border last:border-0">
              <div class="absolute -left-[calc(2rem+7px)] top-5 w-3 h-3 rounded-full bg-text" />
              <span class="font-sans text-sm text-secondary block">{year}</span>
              <span class="font-sans text-base text-text block mt-1">{text}</span>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
