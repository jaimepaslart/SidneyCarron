---
import PageLayout from '@/layouts/PageLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Sidney Carron',
      jobTitle: lang === 'fr' ? 'Artiste — Empreintes solaires' : 'Artist — Solar Imprints',
      description: lang === 'fr'
        ? 'Artiste contemporaine explorant l\'empreinte solaire, l\'héliographie et le dialogue entre corps, lumière et matière photosensible.'
        : 'Contemporary artist exploring solar imprints, heliography and the dialogue between body, light and photosensitive material.',
      image: `${siteUrl}/images/portrait-sidney-carron.jpg`,
      url: siteUrl,
      email: 'contact@sidneycarron.com',
      sameAs: [
        'https://instagram.com/sidneycarron',
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: lang === 'fr' ? 'À propos' : 'About' },
      ],
    },
  ],
};

const bio = lang === 'fr' ? {
  title: 'À propos de Sidney Carron',
  intro: 'Née à Vienne, dans l\'Isère, Sidney Carron est une artiste dont le travail explore le dialogue entre le corps, la lumière et les éléments naturels. Photographe, joaillière, voyageuse — elle écrit avec la lumière.',
  bioTitle: 'Biographie',
  bioText: `Passionnée de peinture dès l'âge de cinq ans, Sidney Carron suit des études de joaillerie à l'École du Louvre, dont elle sort deuxième de sa promotion. Elle commence à fabriquer des bijoux place Vendôme, avant de tout quitter pour se consacrer à la photographie.

Habitée par une soif de liberté inextinguible, refusant tout ancrage, elle s'envole en Afrique, en Amérique et en Israël pour des reportages photographiques. Autodidacte, elle dit avoir été « éduquée par les voyages et les rencontres ». Depuis l'enfance, elle découpe des mini-Polaroids pour fabriquer des romans-photos — première manifestation d'un instinct narratif par l'image.

À son retour, elle réalise des projets remarqués : la couverture de Playboy avec Joey Starr, le clip « Dangereuse » du chanteur Christophe, l'affiche du DJ set littéraire de Frédéric Beigbeder. Mais c'est dans le retour aux origines de la photographie qu'elle trouve sa voie la plus profonde.

Aujourd'hui, Sidney Carron aborde la photographie à partir de sa matrice originelle : le travail de la lumière. Elle travaille dehors, au bord de l'eau, en disposant corps, fragments végétaux, branches et pierres directement sur la surface photosensible, laissant le soleil, le vent, le sable et la mer intervenir dans l'image.

Elle est représentée par la Sakanagallery à Donostia / San Sebastián.`,
  statement: `« J'écris avec la lumière. Pour être en osmose, en accord total avec la nature, j'ai remplacé l'appareil photo par le soleil. »`,
  cvTitle: 'Parcours',
  cvItems: [
    { year: 'Enfance', text: 'Née à Vienne (Isère) — passionnée de peinture dès l\'âge de cinq ans' },
    { year: 'Formation', text: 'Études de joaillerie à l\'École du Louvre (2e de sa promotion)' },
    { year: 'Joaillerie', text: 'Création de bijoux place Vendôme, puis rupture pour la photographie' },
    { year: 'Reportages', text: 'Voyages en Afrique, Amérique et Israël — « éduquée par les voyages et les rencontres »' },
    { year: 'Photographie', text: 'Couverture Playboy (Joey Starr), clip « Dangereuse » (Christophe), affiche DJ set littéraire (Beigbeder)' },
    { year: 'Aujourd\'hui', text: 'Empreintes solaires — technique sur papier photosensible en plein air' },
    { year: 'Galerie', text: 'Représentée par Sakanagallery, Donostia / San Sebastián' },
  ],
} : {
  title: 'About Sidney Carron',
  intro: 'Born in Vienne, in the Isère region of France, Sidney Carron is an artist whose work explores the dialogue between body, light and the natural elements. Photographer, jeweller, traveller — she writes with light.',
  bioTitle: 'Biography',
  bioText: `Passionate about painting from the age of five, Sidney Carron studied jewellery at the École du Louvre, graduating second in her class. She began crafting jewellery on Place Vendôme before leaving everything behind to devote herself to photography.

Driven by an insatiable thirst for freedom, refusing any permanent home, she travelled to Africa, the Americas and Israel for photographic reportage. Self-taught, she says she was "educated by travel and encounters." Since childhood, she had been cutting mini-Polaroids to create photo-novels — the first sign of a narrative instinct through images.

On her return, she completed notable projects: the Playboy cover featuring Joey Starr, the music video for "Dangereuse" by the singer Christophe, and the poster for Frédéric Beigbeder's literary DJ set. But it is in returning to the origins of photography that she found her deepest calling.

Today, Sidney Carron approaches photography from its original matrix: the work of light. She works outdoors, by the water, placing bodies, plant fragments, branches and stones directly onto photosensitive paper, letting the sun, wind, sand and sea intervene in the image.

She is represented by Sakanagallery in Donostia / San Sebastián.`,
  statement: `"I write with light. To be in osmosis, in total harmony with nature, I replaced the camera with the sun."`,
  cvTitle: 'Background',
  cvItems: [
    { year: 'Childhood', text: 'Born in Vienne (Isère, France) — passionate about painting from the age of five' },
    { year: 'Education', text: 'Jewellery studies at the École du Louvre (2nd in class)' },
    { year: 'Jewellery', text: 'Crafting jewellery on Place Vendôme, then a break for photography' },
    { year: 'Reportage', text: 'Travels in Africa, the Americas and Israel — "educated by travel and encounters"' },
    { year: 'Photography', text: 'Playboy cover (Joey Starr), "Dangereuse" music video (Christophe), literary DJ set poster (Beigbeder)' },
    { year: 'Today', text: 'Solar imprints — photosensitive paper technique in the open air' },
    { year: 'Gallery', text: 'Represented by Sakanagallery, Donostia / San Sebastián' },
  ],
};
---

<PageLayout
  title={`${t('about.title')} — Sidney Carron`}
  description={t('about.description')}
  ogImage="/images/portrait-sidney-carron.jpg"
  canonicalPath="/about"
  jsonLd={jsonLd}
>
  <!-- 1. Split portrait/intro -->
  <section class="museum-section">
    <div class="museum-container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-16">
        <!-- Portrait (40%) -->
        <div class="lg:col-span-2">
          <ScrollReveal>
            <div class="overflow-hidden bg-[#F5F5F5]">
              <img
                src="/images/portrait-sidney-carron.jpg"
                alt={lang === 'fr' ? 'Portrait de Sidney Carron' : 'Portrait of Sidney Carron'}
                width="600"
                height="800"
                loading="eager"
                class="w-full h-auto object-cover"
              />
            </div>
          </ScrollReveal>
        </div>

        <!-- Intro (60%) -->
        <div class="lg:col-span-3 flex flex-col justify-center">
          <ScrollReveal delay={100}>
            <h1 class="font-serif font-light text-4xl text-text">{bio.title}</h1>
            <p class="font-sans text-lg text-text mt-6 leading-relaxed">{bio.intro}</p>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Biography -->
  <section class="museum-section border-t border-border">
    <div class="museum-container max-w-3xl">
      <ScrollReveal>
        <h2 class="font-serif font-light text-2xl text-text mb-6">{bio.bioTitle}</h2>
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <div class="font-sans text-base text-text leading-relaxed space-y-4">
          {bio.bioText.split('\n\n').map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- 3. Artistic statement -->
  <section class="museum-section border-t border-border">
    <div class="museum-container">
      <ScrollReveal>
        <blockquote class="font-serif italic text-2xl md:text-3xl text-center max-w-3xl mx-auto text-text leading-relaxed">
          {bio.statement}
        </blockquote>
      </ScrollReveal>
    </div>
  </section>

  <!-- 4. CV / Timeline -->
  <section class="museum-section border-t border-border">
    <div class="museum-container max-w-3xl">
      <ScrollReveal>
        <h2 class="font-serif font-light text-2xl text-text mb-8">{bio.cvTitle}</h2>
      </ScrollReveal>
      <div class="relative border-l-2 border-border pl-8 ml-1.5 space-y-0">
        {bio.cvItems.map(({ year, text }, i) => (
          <ScrollReveal delay={i * 80}>
            <div class="relative py-4 border-b border-border last:border-0">
              <div class="absolute -left-[calc(2rem+7px)] top-5 w-3 h-3 rounded-full bg-text" />
              <span class="font-sans text-sm text-secondary block">{year}</span>
              <span class="font-sans text-base text-text block mt-1">{text}</span>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
