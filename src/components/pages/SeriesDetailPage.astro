---
import PageLayout from '@/layouts/PageLayout.astro';
import WorkCard from '@/components/WorkCard.astro';
import MasonryGallery from '@/components/MasonryGallery.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = getTranslation(lang);

const allSeries = await getCollection('series');
const series = allSeries.find(s =>
  (lang === 'en' ? s.data.slug_en : s.data.slug) === slug
);

if (!series) return Astro.redirect(getLocalizedPath(lang, '/series'));

const title = lang === 'en' ? series.data.title_en : series.data.title_fr;
const description = lang === 'en' ? series.data.description_en : series.data.description_fr;
const curatorial = lang === 'en' ? series.data.curatorial_en : series.data.curatorial_fr;

const allWorks = await getCollection('works');
const seriesWorks = allWorks
  .filter(w => w.data.series === series.data.slug)
  .sort((a, b) => a.data.order - b.data.order);

const countLabel = lang === 'en'
  ? `${seriesWorks.length} ${seriesWorks.length <= 1 ? 'work' : 'works'}`
  : `${seriesWorks.length} ${seriesWorks.length <= 1 ? 'œuvre' : 'œuvres'}`;

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: title,
      description: description,
      url: `${siteUrl}${getLocalizedPath(lang, `/series/${series.data.slug}`)}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: lang === 'fr' ? 'Séries' : 'Series', item: `${siteUrl}${getLocalizedPath(lang, '/series')}` },
        { '@type': 'ListItem', position: 3, name: title },
      ],
    },
  ],
};
---

<PageLayout
  title={`${title} — ${t('series.title')} — Sidney Carron`}
  description={description}
  ogImage={series.data.cover.src}
  canonicalPath={`/series/${series.data.slug}`}
  enCanonicalPath={`/series/${series.data.slug_en}`}
  jsonLd={jsonLd}
>
  <!-- Hero: full-width cover -->
  <section class="relative">
    <div class="w-full max-h-[60vh] overflow-hidden bg-[#F5F5F5]">
      <img
        src={series.data.cover.src}
        alt={lang === 'en' ? series.data.cover.alt_en : series.data.cover.alt_fr}
        width="1280"
        height="550"
        loading="eager"
        class="w-full h-full object-cover"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end">
      <div class="museum-container pb-8 md:pb-12">
        <h1 class="font-serif font-light text-4xl md:text-5xl lg:text-6xl text-white drop-shadow-lg">
          {title}
        </h1>
      </div>
    </div>
  </section>

  <!-- Info section -->
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <a
          href={getLocalizedPath(lang, '/series')}
          class="inline-block font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease mb-6"
        >
          &larr; {t('series.back')}
        </a>
        <p class="text-sm text-secondary uppercase tracking-widest">{countLabel}</p>
      </ScrollReveal>

      {description && (
        <ScrollReveal delay={100}>
          <p class="font-serif text-lg text-text max-w-3xl mt-6 leading-relaxed">{description}</p>
        </ScrollReveal>
      )}

      {curatorial && (
        <ScrollReveal delay={200}>
          <p class="font-sans text-base text-secondary max-w-3xl mt-4 leading-relaxed">{curatorial}</p>
        </ScrollReveal>
      )}
    </div>
  </section>

  <!-- Works in this series -->
  <section class="museum-section border-t border-border">
    <div class="museum-container">
      <MasonryGallery>
        {seriesWorks.map((work, i) => (
          <div class="break-inside-avoid mb-4 md:mb-6">
            <ScrollReveal delay={i * 100}>
              <WorkCard
                slug={lang === 'en' ? work.data.slug_en : work.data.slug}
                title={lang === 'en' ? work.data.title_en : work.data.title_fr}
                year={work.data.year}
                medium={lang === 'en' ? work.data.medium_en : work.data.medium_fr}
                image={{
                  src: work.data.images[0].src,
                  alt: lang === 'en' ? work.data.images[0].alt_en : work.data.images[0].alt_fr,
                }}
              />
            </ScrollReveal>
          </div>
        ))}
      </MasonryGallery>
    </div>
  </section>
</PageLayout>
