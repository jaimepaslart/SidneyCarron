---
import PageLayout from '@/layouts/PageLayout.astro';
import ExhibitionTimeline from '@/components/ExhibitionTimeline.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const allExhibitions = await getCollection('exhibitions');

// Sort: upcoming first, then current, then past (by date descending)
const sorted = allExhibitions
  .map(e => ({
    slug: lang === 'en' ? e.data.slug_en : e.data.slug,
    title: lang === 'en' ? e.data.title_en : e.data.title_fr,
    venue: lang === 'en' ? e.data.venue_en : e.data.venue_fr,
    city: e.data.city,
    start_date: e.data.start_date,
    end_date: e.data.end_date,
    status: e.data.status as 'upcoming' | 'current' | 'past',
  }))
  .sort((a, b) => {
    const statusOrder = { upcoming: 0, current: 1, past: 2 };
    const sA = statusOrder[a.status] ?? 2;
    const sB = statusOrder[b.status] ?? 2;
    if (sA !== sB) return sA - sB;
    return new Date(b.start_date).getTime() - new Date(a.start_date).getTime();
  });

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: t('exhibitions.title'),
      description: t('exhibitions.description'),
      url: `${siteUrl}${getLocalizedPath(lang, '/exhibitions')}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: lang === 'fr' ? 'Expositions' : 'Exhibitions' },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('exhibitions.title')} — Sidney Carron`}
  description={t('exhibitions.description')}
  canonicalPath="/exhibitions"
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <h1 class="font-serif font-light text-4xl text-text mb-8 md:mb-12">
          {t('exhibitions.title')}
        </h1>
      </ScrollReveal>

      <ExhibitionTimeline exhibitions={sorted} lang={lang} />
    </div>
  </section>
</PageLayout>
