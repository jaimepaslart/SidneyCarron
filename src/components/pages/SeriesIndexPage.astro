---
import PageLayout from '@/layouts/PageLayout.astro';
import SeriesCard from '@/components/SeriesCard.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const allSeries = await getCollection('series');
const series = allSeries.sort((a, b) => a.data.order - b.data.order);

const allWorks = await getCollection('works');

function getWorksCount(seriesSlug: string): number {
  return allWorks.filter(w => w.data.series === seriesSlug).length;
}

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: t('series.title'),
      description: t('series.description'),
      url: `${siteUrl}${getLocalizedPath(lang, '/series')}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: lang === 'fr' ? 'Séries' : 'Series' },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('series.title')} — Sidney Carron`}
  description={t('series.description')}
  canonicalPath="/series"
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <h1 class="font-serif font-light text-4xl text-text mb-8 md:mb-12">{t('series.title')}</h1>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {series.map((s, i) => (
          <ScrollReveal delay={i * 100}>
            <SeriesCard
              series={{
                title: lang === 'en' ? s.data.title_en : s.data.title_fr,
                slug: lang === 'en' ? s.data.slug_en : s.data.slug,
                cover: {
                  src: s.data.cover.src,
                  alt: lang === 'en' ? s.data.cover.alt_en : s.data.cover.alt_fr,
                },
                description: lang === 'en' ? s.data.description_en : s.data.description_fr,
              }}
              workCount={getWorksCount(s.data.slug)}
              lang={lang}
            />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
