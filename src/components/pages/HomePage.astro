---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import LocationCard from '@/components/LocationCard.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import HomeExhibitionsSection from '@/components/HomeExhibitionsSection.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';
import { locations, getLocation } from '@/data/locations';
import { getHome, getSettings, localize, SITE_URL } from '@/utils/site';
import { buildPersonSchema, buildBreadcrumbs } from '@/utils/seo';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

// Featured locations from CMS
const homeData = getHome();
const featuredSlugs = homeData.featured_locations;
const featuredLocations = featuredSlugs
  .map(slug => getLocation(slug))
  .filter((loc): loc is NonNullable<typeof loc> => loc !== undefined);

// All exhibitions sorted by start_date desc
const allExhibitions = await getCollection('exhibitions');
const sortedExhibitions = allExhibitions
  .sort((a, b) => new Date(b.data.start_date).getTime() - new Date(a.data.start_date).getTime());

// Artist statement from CMS
const artistStatement = localize(lang, homeData.hero_statement_fr, homeData.hero_statement_en);

const cartePath = lang === 'fr' ? '/carte/' : '/en/map/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Sidney Carron',
      url: SITE_URL,
      inLanguage: [lang === 'fr' ? 'fr-FR' : 'en-US'],
    },
    buildPersonSchema(lang),
  ],
};
---

<PageLayout
  title={t('home.title')}
  description={t('home.description')}
  jsonLd={jsonLd}
  hideHeader={true}
>
  <!-- 1. Hero Section (includes static header + artist name + parallax image) -->
  <HeroSection lang={lang} />

  <!-- 2. Exhibitions Section (Rinaldi-style) — right after hero -->
  {sortedExhibitions.length > 0 && (
    <HomeExhibitionsSection lang={lang} exhibitions={sortedExhibitions} videoSrc="/videos/sid-reel.mp4" />
  )}

  <!-- 3. Featured Locations -->
  {featuredLocations.length > 0 && (
    <section class="museum-section">
      <div class="museum-container">
        <ScrollReveal>
          <p class="text-sm uppercase tracking-widest text-secondary mb-8">{t('home.featured.label')}</p>
        </ScrollReveal>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          {featuredLocations.map((loc, i) => (
            <ScrollReveal delay={i * 100}>
              <LocationCard location={loc} lang={lang} />
            </ScrollReveal>
          ))}
        </div>
        <ScrollReveal delay={300}>
          <div class="text-center mt-12">
            <a
              href={getLocalizedPath(lang, cartePath)}
              class="font-sans text-sm text-secondary hover:text-text transition-colors duration-300 ease"
            >
              {t('home.featured.cta')} &rarr;
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>
  )}

  <!-- 4. Artist Statement -->
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <blockquote class="text-2xl md:text-4xl font-sans italic text-center max-w-3xl mx-auto text-text leading-relaxed">
          &laquo; {artistStatement} &raquo;
        </blockquote>
      </ScrollReveal>
    </div>
  </section>
</PageLayout>
