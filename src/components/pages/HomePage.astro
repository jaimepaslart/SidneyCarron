---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import WorkCard from '@/components/WorkCard.astro';
import MasonryGallery from '@/components/MasonryGallery.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

// Hero data (matches home.yaml values via i18n)
const heroStatement = t('home.hero.statement');
const heroSubtitle = t('home.hero.subtitle');

// Featured works
const allWorks = await getCollection('works');
const featuredWorks = allWorks
  .filter(w => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// Current/upcoming exhibition
const allExhibitions = await getCollection('exhibitions');
const currentExhibition = allExhibitions
  .filter(e => e.data.status === 'current' || e.data.status === 'upcoming')
  .sort((a, b) => new Date(a.data.start_date).getTime() - new Date(b.data.start_date).getTime())
  [0];

function formatDates(startStr: string, endStr: string): string {
  const start = new Date(startStr);
  const end = new Date(endStr);
  const sd = String(start.getDate()).padStart(2, '0');
  const sm = String(start.getMonth() + 1).padStart(2, '0');
  const ed = String(end.getDate()).padStart(2, '0');
  const em = String(end.getMonth() + 1).padStart(2, '0');
  const ey = end.getFullYear();
  if (start.getFullYear() === end.getFullYear()) {
    return `${sd}.${sm} — ${ed}.${em}.${ey}`;
  }
  return `${sd}.${sm}.${start.getFullYear()} — ${ed}.${em}.${ey}`;
}

// Artist statement
const artistStatement = lang === 'en'
  ? "I write with light. To be in osmosis, in total harmony with nature, I replaced the camera with the sun."
  : "J'écris avec la lumière. Pour être en osmose, en accord total avec la nature, j'ai remplacé l'appareil photo par le soleil.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Sidney Carron',
      url: 'https://sidneycarron.com',
      inLanguage: [lang === 'fr' ? 'fr-FR' : 'en-US'],
    },
    {
      '@type': 'Person',
      name: 'Sidney Carron',
      jobTitle: lang === 'fr' ? 'Artiste photographe' : 'Visual artist & photographer',
      description: lang === 'fr'
        ? 'Artiste contemporaine explorant l\'empreinte solaire, l\'héliographie et le dialogue entre corps, lumière et matière photosensible.'
        : 'Contemporary artist exploring solar imprints, heliography and the dialogue between body, light and photosensitive material.',
      url: 'https://sidneycarron.com',
      image: 'https://sidneycarron.com/images/portrait-sidney-carron.jpg',
      sameAs: [
        'https://instagram.com/sidneycarron',
      ],
    },
  ],
};
---

<PageLayout
  title={t('home.title')}
  description={t('home.description')}
  jsonLd={jsonLd}
>
  <!-- 1. Hero Section -->
  <HeroSection statement={heroStatement} subtitle={heroSubtitle} lang={lang} />

  <!-- 2. Featured Works in MasonryGallery -->
  {featuredWorks.length > 0 && (
    <section class="museum-section">
      <div class="museum-container">
        <ScrollReveal>
          <p class="text-sm uppercase tracking-widest text-secondary mb-8">{t('home.featured.label')}</p>
        </ScrollReveal>
        <MasonryGallery>
          {featuredWorks.map((work, i) => (
            <div class="break-inside-avoid mb-4 md:mb-6">
              <ScrollReveal delay={i * 100}>
                <WorkCard
                  slug={lang === 'en' ? work.data.slug_en : work.data.slug}
                  title={lang === 'en' ? work.data.title_en : work.data.title_fr}
                  year={work.data.year}
                  medium={lang === 'en' ? work.data.medium_en : work.data.medium_fr}
                  image={{
                    src: work.data.images[0].src,
                    alt: lang === 'en' ? work.data.images[0].alt_en : work.data.images[0].alt_fr,
                  }}
                />
              </ScrollReveal>
            </div>
          ))}
        </MasonryGallery>
        <ScrollReveal delay={300}>
          <div class="text-center mt-12">
            <a
              href={getLocalizedPath(lang, '/works')}
              class="font-sans text-sm text-secondary hover:text-hover transition-colors duration-hover ease"
            >
              {t('home.featured.cta')} &rarr;
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>
  )}

  <!-- 3. Current/Upcoming Exhibition Banner -->
  {currentExhibition && (
    <ScrollReveal tag="section">
      <div class="bg-[#1A1A1A] text-white">
        <div class="museum-container py-section-sm md:py-section-md lg:py-section-lg">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
            {currentExhibition.data.image && (
              <div class="overflow-hidden">
                <img
                  src={currentExhibition.data.image.src}
                  alt={lang === 'en' ? currentExhibition.data.image.alt_en : currentExhibition.data.image.alt_fr}
                  width="800"
                  height="600"
                  loading="lazy"
                  class="w-full h-auto object-cover"
                />
              </div>
            )}
            <div>
              <p class="text-xs uppercase tracking-widest text-white/60 mb-4">
                {currentExhibition.data.status === 'current'
                  ? t('exhibitions.current_badge')
                  : t('exhibitions.upcoming_badge')}
              </p>
              <h2 class="font-serif font-light text-3xl md:text-4xl lg:text-5xl text-white">
                {lang === 'en' ? currentExhibition.data.title_en : currentExhibition.data.title_fr}
              </h2>
              <p class="font-sans text-base text-white/70 mt-4">
                {lang === 'en' ? currentExhibition.data.venue_en : currentExhibition.data.venue_fr}, {currentExhibition.data.city}
              </p>
              <p class="font-sans text-sm text-white/50 mt-2">
                {formatDates(currentExhibition.data.start_date, currentExhibition.data.end_date)}
              </p>
              <div class="mt-8">
                <a
                  href={getLocalizedPath(lang, `/exhibitions/${lang === 'en' ? currentExhibition.data.slug_en : currentExhibition.data.slug}`)}
                  class="font-sans text-sm text-white/70 hover:text-white transition-colors duration-hover ease"
                >
                  {t('home.exhibitions.cta')} &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ScrollReveal>
  )}

  <!-- 4. Artist Statement -->
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <blockquote class="text-2xl md:text-4xl font-serif italic text-center max-w-3xl mx-auto text-text leading-relaxed">
          &laquo; {artistStatement} &raquo;
        </blockquote>
      </ScrollReveal>
    </div>
  </section>
</PageLayout>
