---
import PageLayout from '@/layouts/PageLayout.astro';
import WorkCard from '@/components/WorkCard.astro';
import MasonryGallery from '@/components/MasonryGallery.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  location: string;
  locationName: string;
  works: any[];
  lang: Lang;
}

const { location, locationName, works, lang } = Astro.props;
const t = getTranslation(lang);

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: `${t('works.title')} — ${locationName}`,
      description: `${t('works.title')} ${lang === 'fr' ? 'réalisées à' : 'created in'} ${locationName}`,
      url: `${siteUrl}${getLocalizedPath(lang, `/works/${location}`)}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: t('works.title'), item: `${siteUrl}${getLocalizedPath(lang, '/works')}` },
        { '@type': 'ListItem', position: 3, name: locationName },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('works.title')} — ${locationName} — Sidney Carron`}
  description={`${t('works.title')} ${lang === 'fr' ? 'réalisées à' : 'created in'} ${locationName}`}
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container">
      <ScrollReveal>
        <a
          href={getLocalizedPath(lang, '/works')}
          class="inline-block font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease mb-8"
        >
          &larr; {t('works.back')}
        </a>
        <h1 class="font-serif font-light text-4xl text-text">{locationName}</h1>
        <p class="text-sm text-secondary uppercase tracking-widest mt-2">
          {works.length} {works.length <= 1 ? t('works.count_singular') : t('works.count_plural')}
        </p>
      </ScrollReveal>

      <div class="mt-12">
        <MasonryGallery>
          {works.map((work, i) => (
            <div class="break-inside-avoid mb-4 md:mb-6">
              <ScrollReveal delay={i * 100}>
                <WorkCard
                  slug={lang === 'en' ? work.data.slug_en : work.data.slug}
                  title={lang === 'en' ? work.data.title_en : work.data.title_fr}
                  year={work.data.year}
                  medium={lang === 'en' ? work.data.medium_en : work.data.medium_fr}
                  image={{
                    src: work.data.images[0].src,
                    alt: lang === 'en' ? work.data.images[0].alt_en : work.data.images[0].alt_fr,
                  }}
                />
              </ScrollReveal>
            </div>
          ))}
        </MasonryGallery>
      </div>
    </div>
  </section>
</PageLayout>
