---
import PageLayout from '@/layouts/PageLayout.astro';
import ImageCarousel from '@/components/ImageCarousel';
import WorkCard from '@/components/WorkCard.astro';
import MasonryGallery from '@/components/MasonryGallery.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = getTranslation(lang);

const allWorks = await getCollection('works');
const sortedWorks = allWorks.sort((a, b) => a.data.order - b.data.order);

const workIndex = sortedWorks.findIndex(w =>
  (lang === 'en' ? w.data.slug_en : w.data.slug) === slug
);
const work = sortedWorks[workIndex];

if (!work) return Astro.redirect(getLocalizedPath(lang, '/works'));

const prevWork = workIndex > 0 ? sortedWorks[workIndex - 1] : null;
const nextWork = workIndex < sortedWorks.length - 1 ? sortedWorks[workIndex + 1] : null;

const title = lang === 'en' ? work.data.title_en : work.data.title_fr;
const medium = lang === 'en' ? work.data.medium_en : work.data.medium_fr;
const description = lang === 'en' ? work.data.description_en : work.data.description_fr;
const locationLabel = t(`works.location.${work.data.location}` as any);

const prevTitle = prevWork ? (lang === 'en' ? prevWork.data.title_en : prevWork.data.title_fr) : '';
const nextTitle = nextWork ? (lang === 'en' ? nextWork.data.title_en : nextWork.data.title_fr) : '';

const images = work.data.images.map((img: any) => ({
  src: img.src,
  alt: lang === 'en' ? img.alt_en : img.alt_fr,
}));

// Related works from same series
const relatedWorks = sortedWorks
  .filter(w => w.data.series === work.data.series && w.data.slug !== work.data.slug)
  .slice(0, 6);

const allSeries = await getCollection('series');
const seriesData = allSeries.find(s => s.data.slug === work.data.series);
const seriesTitle = seriesData ? (lang === 'en' ? seriesData.data.title_en : seriesData.data.title_fr) : '';
const seriesSlug = seriesData ? (lang === 'en' ? seriesData.data.slug_en : seriesData.data.slug) : '';

const siteUrl = 'https://sidneycarron.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VisualArtwork',
      name: title,
      description: description || `${title}, ${medium}, ${work.data.year}`,
      dateCreated: String(work.data.year),
      artMedium: medium,
      width: work.data.dimensions,
      image: `${siteUrl}${work.data.images[0].src}`,
      url: `${siteUrl}${getLocalizedPath(lang, `/works/${work.data.slug}`)}`,
      creator: {
        '@type': 'Person',
        name: 'Sidney Carron',
        url: siteUrl,
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: lang === 'fr' ? 'Œuvres' : 'Works', item: `${siteUrl}${getLocalizedPath(lang, '/works')}` },
        { '@type': 'ListItem', position: 3, name: title },
      ],
    },
  ],
};
---

<PageLayout
  title={`${title} — Sidney Carron`}
  description={description || `${title}, ${medium}, ${work.data.year}`}
  ogImage={work.data.images[0].src}
  canonicalPath={`/works/${work.data.slug}`}
  enCanonicalPath={`/works/${work.data.slug_en}`}
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container">
      <!-- Split layout: 60% images / 40% info -->
      <div class="flex flex-col lg:flex-row lg:gap-16">

        <!-- LEFT: Images (60%) -->
        <div class="lg:w-[60%]">
          {images.length > 1 ? (
            <ImageCarousel images={images} title={title} client:visible />
          ) : (
            <div class="bg-[#F5F5F5]">
              <img
                src={images[0].src}
                alt={images[0].alt}
                width="800"
                height="1000"
                loading="eager"
                class="w-full h-auto object-contain"
              />
            </div>
          )}
        </div>

        <!-- RIGHT: Info (40%, sticky) -->
        <div class="lg:w-[40%] mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24 detail-info">
            <!-- Back link -->
            <a
              href={getLocalizedPath(lang, '/works')}
              class="inline-block font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease mb-6"
            >
              &larr; {t('works.back')}
            </a>

            <!-- Title -->
            <h1 class="font-serif font-light text-3xl text-text">{title}</h1>

            <!-- Metadata -->
            <dl class="mt-8 space-y-5">
              <div>
                <dt class="text-xs uppercase tracking-widest text-secondary">{t('works.year')}</dt>
                <dd class="text-base text-text mt-1">{work.data.year}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-secondary">{t('works.medium')}</dt>
                <dd class="text-base text-text mt-1">{medium}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest text-secondary">{t('works.dimensions')}</dt>
                <dd class="text-base text-text mt-1">{work.data.dimensions}</dd>
              </div>
              {seriesData && (
                <div>
                  <dt class="text-xs uppercase tracking-widest text-secondary">{t('works.series')}</dt>
                  <dd class="mt-1">
                    <a
                      href={getLocalizedPath(lang, `/series/${seriesSlug}`)}
                      class="text-base text-text hover:text-hover transition-colors duration-hover ease underline underline-offset-2"
                    >
                      {seriesTitle}
                    </a>
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-xs uppercase tracking-widest text-secondary">{t('works.location')}</dt>
                <dd class="mt-1">
                  <a
                    href={getLocalizedPath(lang, `/works/${work.data.location}`)}
                    class="text-base text-text hover:text-hover transition-colors duration-hover ease underline underline-offset-2"
                  >
                    {locationLabel}
                  </a>
                </dd>
              </div>
            </dl>

            <!-- Description -->
            {description && (
              <div class="mt-8 pt-6 border-t border-border">
                <p class="font-sans text-base text-text leading-relaxed">{description}</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Prev / Next navigation -->
  <nav class="border-t border-border" aria-label={lang === 'fr' ? 'Navigation entre œuvres' : 'Works navigation'}>
    <div class="museum-container py-8 flex justify-between items-start">
      {prevWork ? (
        <a
          href={getLocalizedPath(lang, `/works/${lang === 'en' ? prevWork.data.slug_en : prevWork.data.slug}`)}
          class="group font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease"
        >
          <span>&larr; {t('works.prev')}</span>
          <span class="block text-xs text-secondary mt-1">{prevTitle}</span>
        </a>
      ) : <span />}
      {nextWork ? (
        <a
          href={getLocalizedPath(lang, `/works/${lang === 'en' ? nextWork.data.slug_en : nextWork.data.slug}`)}
          class="group font-sans text-sm text-secondary hover:text-text transition-colors duration-hover ease text-right"
        >
          <span>{t('works.next')} &rarr;</span>
          <span class="block text-xs text-secondary mt-1">{nextTitle}</span>
        </a>
      ) : <span />}
    </div>
  </nav>

  <!-- Related works from same series -->
  {relatedWorks.length > 0 && (
    <section class="museum-section border-t border-border">
      <div class="museum-container">
        <ScrollReveal>
          <h2 class="font-serif font-light text-2xl text-text mb-8">
            {t('works.related')}
          </h2>
        </ScrollReveal>
        <MasonryGallery>
          {relatedWorks.map((rw, i) => (
            <div class="break-inside-avoid mb-4 md:mb-6">
              <ScrollReveal delay={i * 100}>
                <WorkCard
                  slug={lang === 'en' ? rw.data.slug_en : rw.data.slug}
                  title={lang === 'en' ? rw.data.title_en : rw.data.title_fr}
                  year={rw.data.year}
                  medium={lang === 'en' ? rw.data.medium_en : rw.data.medium_fr}
                  image={{
                    src: rw.data.images[0].src,
                    alt: lang === 'en' ? rw.data.images[0].alt_en : rw.data.images[0].alt_fr,
                  }}
                />
              </ScrollReveal>
            </div>
          ))}
        </MasonryGallery>
      </div>
    </section>
  )}
</PageLayout>

<style>
  .detail-info {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeInUp 600ms ease-out 100ms forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .detail-info {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
