---
import PageLayout from '@/layouts/PageLayout.astro';
import CobeGlobe from '@/components/CobeGlobe.astro';
import GlobeLocationList from '@/components/GlobeLocationList.astro';
import LocationList from '@/components/LocationList.astro';
import { getTranslation, getLocalizedPath, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const siteUrl = 'https://sidneycarron.com';
const mapPath = lang === 'fr' ? '/carte/' : '/en/map/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: t('map.title'),
      description: t('map.subtitle'),
      url: `${siteUrl}${mapPath}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: t('map.title') },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('map.title')} — Sidney Carron`}
  description={t('map.subtitle')}
  canonicalPath={lang === 'fr' ? '/carte' : '/en/map'}
  jsonLd={jsonLd}
>
  <section class="museum-section">
    <div class="museum-container">
      <h1 class="font-display font-light text-4xl md:text-5xl text-text mb-4">
        {t('map.title')}
      </h1>
      <p class="font-sans text-lg text-secondary max-w-2xl">
        {t('map.subtitle')}
      </p>

      <!-- Desktop: Globe + List (md+) -->
      <div class="mt-12 md:mt-16 hidden md:grid md:grid-cols-2 md:gap-12 items-start">
        <div class="sticky top-24">
          <CobeGlobe lang={lang} />
        </div>
        <GlobeLocationList lang={lang} />
      </div>

      <!-- Mobile: Location List (< md) -->
      <div class="mt-8 md:hidden">
        <LocationList lang={lang} />
      </div>
    </div>
  </section>
</PageLayout>
