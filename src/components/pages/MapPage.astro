---
import PageLayout from '@/layouts/PageLayout.astro';
import CobeGlobe from '@/components/CobeGlobe.astro';
import GlobeLocationList from '@/components/GlobeLocationList.astro';
import { getTranslation, type Lang } from '@/i18n';
import { SITE_URL } from '@/utils/site';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const mapPath = lang === 'fr' ? '/carte/' : '/en/map/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: t('map.title'),
      description: t('map.subtitle'),
      url: `${SITE_URL}${mapPath}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Sidney Carron', item: SITE_URL },
        { '@type': 'ListItem', position: 2, name: t('map.title') },
      ],
    },
  ],
};
---

<PageLayout
  title={`${t('map.title')} — Sidney Carron`}
  description={t('map.subtitle')}
  canonicalPath={lang === 'fr' ? '/carte' : '/en/map'}
  jsonLd={jsonLd}
>
  <section class="map-section">
    <div class="map-header museum-container">
      <h1 class="font-display font-light text-4xl md:text-5xl text-text mb-4">
        {t('map.title')}
      </h1>
      <p class="font-sans text-lg text-secondary max-w-2xl">
        {t('map.subtitle')}
      </p>
    </div>

    <!-- Globe + Liste — layout 2 colonnes desktop, empilé mobile -->
    <div class="map-globe" data-map-globe>
      <div class="map-globe__grid">

        <!-- Liste des lieux — colonne gauche sur desktop -->
        <div class="map-globe__list">
          <GlobeLocationList lang={lang} />
        </div>

        <!-- Globe — colonne droite sur desktop -->
        <div class="map-globe__sphere">
          <CobeGlobe lang={lang} showPins={true} rotationSpeed={0.004} heroMode={true} />
        </div>

      </div>
    </div>
  </section>
</PageLayout>

<style>
  .map-section {
    padding-bottom: 5rem;
  }

  .map-header {
    padding-top: 3rem;
    padding-bottom: 0;
  }

  @media (min-width: 1024px) {
    .map-header {
      padding-top: 6rem;
    }
  }

  /* Globe container */
  .map-globe {
    width: 100%;
    margin-top: 2rem;
    padding: 0 1.25rem 0;
    opacity: 0;
    transform: translateY(40px);
  }

  .map-globe--revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 1s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* Mobile : liste d'abord, globe ensuite */
  .map-globe__grid {
    display: flex;
    flex-direction: column-reverse;
    gap: 2.5rem;
  }

  /* Globe centré sur mobile */
  .map-globe__sphere {
    display: flex;
    justify-content: center;
  }

  .map-globe__sphere :global(.cobe-globe) {
    width: 100%;
  }

  .map-globe__sphere :global(.cobe-globe__sphere) {
    max-width: min(86vw, 380px);
    margin: 0 auto;
  }

  /* Override hidden md:block du CobeGlobe pour mobile */
  .map-globe__sphere :global(.cobe-globe) {
    display: block !important;
  }

  /* Override hidden md:block du GlobeLocationList pour mobile */
  .map-globe__list > :global(div) {
    display: block;
  }

  /* Desktop (≥ 768px) : 2 colonnes égales — liste | globe */
  @media (min-width: 768px) {
    .map-globe {
      margin-top: 3rem;
      padding: 0 2rem 0;
    }

    .map-globe__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .map-globe__sphere :global(.cobe-globe__sphere) {
      max-width: min(52vw, 480px);
      margin: 0 auto;
    }
  }

  /* Grand écran (≥ 1024px) */
  @media (min-width: 1024px) {
    .map-globe {
      margin-top: 5rem;
      padding: 0 7.5% 0;
    }

    .map-globe__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .map-globe__sphere :global(.cobe-globe__sphere) {
      max-width: 540px;
    }

    .map-globe__list {
      display: flex;
      align-items: center;
    }

    .map-globe__list > :global(div) {
      width: 100%;
    }

    .map-globe__list :global(.globe-list) {
      max-width: none;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .map-globe {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initMapReveal() {
    const globe = document.querySelector<HTMLElement>('[data-map-globe]');
    if (!globe) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      globe.classList.add('map-globe--revealed');
      return;
    }

    setTimeout(() => globe.classList.add('map-globe--revealed'), 300);
  }

  initMapReveal();
  document.addEventListener('astro:page-load', initMapReveal);
</script>
