---
import { getTranslation, getLocalizedPath } from '@/i18n';
import type { Lang } from '@/i18n';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: Lang;
  alternateHref?: string;
}

const { lang, alternateHref } = Astro.props;
const t = getTranslation(lang);

const locationLinks = [
  { label: t('nav.location.bresil'), href: getLocalizedPath(lang, '/works/bresil/') },
  { label: t('nav.location.dakar'), href: getLocalizedPath(lang, '/works/dakar/') },
  { label: t('nav.location.saint-tropez'), href: getLocalizedPath(lang, '/works/saint-tropez/') },
  { label: t('nav.location.reunion'), href: getLocalizedPath(lang, '/works/reunion/') },
  { label: t('nav.location.sri-lanka'), href: getLocalizedPath(lang, '/works/sri-lanka/') },
  { label: t('nav.location.costa-rica'), href: getLocalizedPath(lang, '/works/costa-rica/') },
];

const pageLinks = [
  { label: t('nav.series'), href: getLocalizedPath(lang, '/series/') },
  { label: t('nav.exhibitions'), href: getLocalizedPath(lang, '/exhibitions/') },
  { label: t('nav.press'), href: getLocalizedPath(lang, '/press/') },
  { label: t('nav.about'), href: getLocalizedPath(lang, '/about/') },
  { label: t('nav.contact'), href: getLocalizedPath(lang, '/contact/') },
];
---

<div
  id="mobile-menu"
  class="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label={t('a11y.main_nav')}
  aria-hidden="true"
>
  <button
    id="mobile-menu-close"
    class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center text-text"
    aria-label={t('a11y.menu_close')}
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="2" y1="2" x2="18" y2="18" />
      <line x1="18" y1="2" x2="2" y2="18" />
    </svg>
  </button>

  <nav class="flex flex-col items-center gap-10 px-6">
    <div class="flex flex-col items-center gap-2">
      {locationLinks.map(({ label, href }, i) => (
        <a
          href={href}
          class="mobile-menu-link font-serif text-3xl font-light text-text"
          style={`--stagger: ${i}`}
        >
          {label}
        </a>
      ))}
    </div>

    <div class="w-12 h-px bg-border" aria-hidden="true"></div>

    <div class="flex flex-col items-center gap-2">
      {pageLinks.map(({ label, href }, i) => (
        <a
          href={href}
          class="mobile-menu-link font-serif text-3xl font-light text-text"
          style={`--stagger: ${locationLinks.length + 1 + i}`}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>

  <div
    class="mobile-menu-link mt-8"
    style={`--stagger: ${locationLinks.length + pageLinks.length + 1}`}
  >
    <LanguageToggle alternateHref={alternateHref} />
  </div>
</div>

<style>
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #FFFFFF;
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-link {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 400ms ease, transform 400ms ease, color 300ms ease;
    transition-delay: calc(var(--stagger, 0) * 50ms);
  }

  .mobile-menu.is-open .mobile-menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu-link:hover {
    color: #666666;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      transition: none;
    }

    .mobile-menu-link {
      opacity: 1;
      transform: none;
      transition: color 200ms ease;
      transition-delay: 0ms;
    }
  }
</style>

<script>
  function initMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    if (!menu) return;

    let isOpen = false;
    let previousFocus: HTMLElement | null = null;

    function getFocusableElements(): HTMLElement[] {
      return Array.from(
        menu!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function open() {
      if (isOpen) return;
      isOpen = true;
      previousFocus = document.activeElement as HTMLElement;
      menu!.classList.add('is-open');
      menu!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      document.dispatchEvent(new CustomEvent('mobile-menu:opened'));

      // Focus first focusable element after animation
      requestAnimationFrame(() => {
        const focusable = getFocusableElements();
        if (focusable.length > 0) focusable[0].focus();
      });
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;
      menu!.classList.remove('is-open');
      menu!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      document.dispatchEvent(new CustomEvent('mobile-menu:closed'));

      // Restore focus
      if (previousFocus) previousFocus.focus();
    }

    // Listen for toggle events from Header
    document.addEventListener('mobile-menu:toggle', () => {
      isOpen ? close() : open();
    });

    document.addEventListener('mobile-menu:close', close);

    // Close button
    closeBtn?.addEventListener('click', close);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        close();
      }
    });

    // Close on link click
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', close);
    });

    // Focus trap
    menu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !isOpen) return;
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }

  // Init on first load
  initMobileMenu();

  // Re-init after ViewTransitions page swap
  document.addEventListener('astro:page-load', () => {
    // Close menu if open (page navigated)
    const menu = document.getElementById('mobile-menu');
    if (menu?.classList.contains('is-open')) {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });
</script>
