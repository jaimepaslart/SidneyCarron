---
import { getTranslation, getLocalizedPath } from '@/i18n';
import { locations } from '@/data/locations';
import type { Lang } from '@/i18n';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: Lang;
  alternateHref?: string;
}

const { lang, alternateHref } = Astro.props;
const t = getTranslation(lang);

const carteLink = {
  label: t('nav.carte'),
  href: getLocalizedPath(lang, lang === 'fr' ? '/carte/' : '/carte/'),
};

const locationLinks = locations.map(loc => ({
  label: t(`nav.location.${loc.slug}` as any),
  href: getLocalizedPath(lang, `/works/${loc.slug}/`),
}));

const pageLinks = [
  { label: t('nav.exhibitions'), href: getLocalizedPath(lang, '/exhibitions/') },
  { label: t('nav.press'), href: getLocalizedPath(lang, '/press/') },
  { label: t('nav.about'), href: getLocalizedPath(lang, '/about/') },
  { label: t('nav.contact'), href: getLocalizedPath(lang, '/contact/') },
];

const allLinks = [carteLink, ...pageLinks, ...locationLinks];
---

<div
  id="mobile-menu"
  class="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label={t('a11y.main_nav')}
  aria-hidden="true"
>
  <!-- Backdrop: blurred page visible on left -->
  <div class="mobile-menu-backdrop" id="mobile-menu-backdrop"></div>

  <!-- Panel: white, slides from right -->
  <div class="mobile-menu-panel">
    <nav class="mobile-menu-nav">
      {allLinks.map(({ label, href }, i) => (
        <a
          href={href}
          class="mobile-menu-link"
          style={`--stagger: ${i}`}
        >
          {label}
        </a>
      ))}
      <div
        class="mobile-menu-link mobile-menu-lang"
        style={`--stagger: ${allLinks.length}`}
      >
        <LanguageToggle alternateHref={alternateHref} />
      </div>
    </nav>
  </div>
</div>

<style>
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    pointer-events: none;
    visibility: hidden;
  }

  .mobile-menu.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  /* Never show on desktop */
  @media (min-width: 1024px) {
    .mobile-menu,
    .mobile-menu.is-open {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
  }

  /* Backdrop: blurred left side */
  .mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 500ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .mobile-menu.is-open .mobile-menu-backdrop {
    opacity: 1;
  }

  /* Panel: white, right side */
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 72%;
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 2rem;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 500ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .mobile-menu.is-open .mobile-menu-panel {
    transform: translateX(0);
  }

  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
  }

  /* Links: Rinaldi-style */
  .mobile-menu-link {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #1A1A1A;
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid #E5E5E5;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 400ms cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 400ms cubic-bezier(0.22, 0.61, 0.36, 1),
                color 200ms ease;
    transition-delay: calc(var(--stagger, 0) * 40ms);
  }

  .mobile-menu-link:first-child {
    border-top: 1px solid #E5E5E5;
  }

  .mobile-menu.is-open .mobile-menu-link {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-menu-link:active {
    color: #666666;
  }

  .mobile-menu-lang {
    border-bottom: none;
    padding-top: 20px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu-backdrop,
    .mobile-menu-panel {
      transition: none;
    }

    .mobile-menu-link {
      opacity: 1;
      transform: none;
      transition: color 200ms ease;
      transition-delay: 0ms;
    }
  }
</style>

<script>
  // Use AbortController to prevent duplicate listeners on re-init
  let menuAbort: AbortController | null = null;

  function initMobileMenu() {
    // Clean up previous listeners
    if (menuAbort) menuAbort.abort();
    menuAbort = new AbortController();
    const signal = menuAbort.signal;

    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    if (!menu) return;

    let isOpen = false;
    let previousFocus: HTMLElement | null = null;

    function getFocusableElements(): HTMLElement[] {
      return Array.from(
        menu!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function open() {
      if (isOpen) return;
      isOpen = true;
      previousFocus = document.activeElement as HTMLElement;
      menu!.classList.add('is-open');
      menu!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      document.dispatchEvent(new CustomEvent('mobile-menu:opened'));

      requestAnimationFrame(() => {
        const focusable = getFocusableElements();
        if (focusable.length > 0) focusable[0].focus();
      });
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;
      menu!.classList.remove('is-open');
      menu!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      document.dispatchEvent(new CustomEvent('mobile-menu:closed'));

      if (previousFocus) previousFocus.focus();
    }

    // Ensure menu is closed on init (e.g. after ViewTransitions navigation)
    if (menu.classList.contains('is-open')) {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.addEventListener('mobile-menu:toggle', () => {
      isOpen ? close() : open();
    }, { signal });

    document.addEventListener('mobile-menu:close', close, { signal });

    backdrop?.addEventListener('click', close, { signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    }, { signal });

    // Close menu if window resizes to desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isOpen) close();
    }, { signal });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', close, { signal });
    });

    menu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !isOpen) return;
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }, { signal });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
